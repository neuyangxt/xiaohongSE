static void UartLinkHandleDownAudioStartFrame(const OhosUartProtoFrame *frame)
{
    uint32_t nowMs = (uint32_t)esp_log_timestamp();
    uint32_t qCount = g_uart_opus_queue_count;
    uint32_t pcmLevel = UartLinkPcmRingLevelSamples();
    uint32_t busy = (qCount > 0U ||
                     pcmLevel > 0U ||
                     g_p4_audio_state == P4_AUDIO_STATE_DOWNLINK_PLAYING ||
                     g_uart_pcm_play_write_busy ||
                     g_uart_opus_decode_push_busy);

    if (frame == NULL || frame->payload_len != 0U) {
        g_uart_down_audio_boundary_invalid++;
        esp_rom_printf("[WS63-UART-DOWN-BOUNDARY] invalid START len=%u invalid=%u\n",
                       frame ? frame->payload_len : 0U,
                       g_uart_down_audio_boundary_invalid);
        return;
    }

    g_uart_down_audio_start_count++;
    g_uart_down_audio_last_start_ms = nowMs;

    if (busy) {
        g_uart_down_audio_start_busy_count++;
        esp_rom_printf("[WS63-UART-DOWN-BOUNDARY] START while busy, keep current session q=%u pcm=%u state=%s writeBusy=%u decodeBusy=%u busyCnt=%u seq=%u startCnt=%u\n",
                       qCount,
                       pcmLevel,
                       P4AudioStateName(g_p4_audio_state),
                       g_uart_pcm_play_write_busy,
                       g_uart_opus_decode_push_busy,
                       g_uart_down_audio_start_busy_count,
                       g_uart_downlink_session_seq,
                       g_uart_down_audio_start_count);
        return;
    }

    g_uart_down_audio_boundary_active = 1U;
    g_uart_down_audio_stop_seen = 0U;
    g_uart_down_audio_explicit_start_pending = 1U;
    g_uart_down_audio_stream_open = 1U;
    g_uart_down_audio_prepare_pending = 1U;
    g_uart_down_audio_wait_more_count = 0U;
    g_uart_down_audio_last_rx_ms = nowMs;
    g_uart_down_audio_prefill_start_ms = nowMs;
    g_uart_downlink_session_seq++;

    if (g_uart_opus_sem_ready) {
        (void)LOS_SemPost(g_uart_opus_sem);
    }

    esp_rom_printf("[WS63-UART-DOWN-BOUNDARY] START count=%u seq=%u busy=%u q=%u pcm=%u state=%s streamOpen=%u preparePending=%u\n",
                   g_uart_down_audio_start_count,
                   g_uart_downlink_session_seq,
                   busy,
                   qCount,
                   pcmLevel,
                   P4AudioStateName(g_p4_audio_state),
                   g_uart_down_audio_stream_open,
                   g_uart_down_audio_prepare_pending);
}

static void UartLinkHandleDownAudioStopFrame(const OhosUartProtoFrame *frame)
{
    uint32_t nowMs = (uint32_t)esp_log_timestamp();

    if (frame == NULL || frame->payload_len != 0U) {
        g_uart_down_audio_boundary_invalid++;
        esp_rom_printf("[WS63-UART-DOWN-BOUNDARY] invalid STOP len=%u invalid=%u\n",
                       frame ? frame->payload_len : 0U,
                       g_uart_down_audio_boundary_invalid);
        return;
    }

    g_uart_down_audio_stop_count++;
    g_uart_down_audio_stop_seen = 1U;
    g_uart_down_audio_prepare_pending = 0U;
    g_uart_down_audio_last_stop_ms = nowMs;
    g_uart_down_audio_last_rx_ms = nowMs;

    if (g_uart_opus_sem_ready) {
        (void)LOS_SemPost(g_uart_opus_sem);
    }
    if (g_uart_pcm_sem_ready) {
        (void)LOS_SemPost(g_uart_pcm_sem);
    }

    esp_rom_printf("[WS63-UART-DOWN-BOUNDARY] STOP count=%u seq=%u active=%u q=%u pcm=%u state=%s frames=%u bytes=%u\n",
                   g_uart_down_audio_stop_count,
                   g_uart_downlink_session_seq,
                   g_uart_down_audio_boundary_active,
                   g_uart_opus_queue_count,
                   UartLinkPcmRingLevelSamples(),
                   P4AudioStateName(g_p4_audio_state),
                   g_uart_down_audio_count,
                   g_uart_down_audio_bytes);
}

static uint32_t UartLinkSendSystemStatusOk(const char *tag)
{
    uint8_t payload[1] = {0};

    if (!g_uart_driver_init_ok) {
        return 0;
    }

    return UartLinkSendProtocolFrame(OHOS_UART_CMD_REPORT_SYSTEM_STATUS,
                                     payload,
                                     sizeof(payload),
                                     tag);
}

static void UartLinkHandleRxFrame(const OhosUartProtoFrame *frame)
{
    if (frame == NULL) {
        return;
    }

    g_uart_rx_frame_count++;
    g_uart_last_rx_cmd = frame->cmd_type;

    if (frame->cmd_type == OHOS_UART_CMD_QUERY_SYSTEM_STATUS) {
        esp_rom_printf("[OHOS-S47H] rx query cmd=0x%04x name=%s len=%u frameCnt=%u\n",
                       frame->cmd_type,
                       OhosUartProtoCmdName(frame->cmd_type),
                       frame->payload_len,
                       g_uart_rx_frame_count);
        uint32_t txOk = UartLinkSendSystemStatusOk("AUTO_REPORT_SYSTEM_STATUS_OK");
        esp_rom_printf("[OHOS-S47H] auto report status-ok txOk=%u linkReady=%u frameCnt=%u\n",
                       txOk,
                       g_uart_link_ready,
                       g_uart_rx_frame_count);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_REPORT_SYSTEM_STATUS) {
        uint32_t status = 0xFFFFFFFFU;

        if (frame->payload_len > 0 && frame->payload != NULL) {
            status = frame->payload[0];
        }

        g_uart_last_system_status = status;
        g_uart_link_ready = (status == 0U);

        esp_rom_printf("[OHOS-S47E] rx frame cmd=0x%04x name=%s len=%u status=%u linkReady=%u frameCnt=%u\n",
                       frame->cmd_type,
                       OhosUartProtoCmdName(frame->cmd_type),
                       frame->payload_len,
                       status,
                       g_uart_link_ready,
                       g_uart_rx_frame_count);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_SET_WAKE_UP_STATUS) {
        UartLinkHandleWakeStatusFrame(frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_AGENT_STATUS) {
        UartLinkHandleAgentStatusFrame(frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_SET_INTERRUPT_MODE) {
        UartLinkHandleInterruptModeFrame(frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_WIFI_SEND_SSID) {
        UartLinkHandleStringData("WIFI_SEND_SSID",
                                 g_uart_wifi_ssid,
                                 OHOS_UART_SMALL_STRING_CAP,
                                 &g_uart_wifi_ssid_len,
                                 frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_WIFI_SEND_PSWD) {
        UartLinkHandleStringData("WIFI_SEND_PSWD",
                                 g_uart_wifi_pswd,
                                 OHOS_UART_SMALL_STRING_CAP,
                                 &g_uart_wifi_pswd_len,
                                 frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_SET_WS_SERVER_URL) {
        UartLinkHandleStringData("SET_WS_SERVER_URL",
                                 g_uart_ws_url,
                                 OHOS_UART_SMALL_STRING_CAP,
                                 &g_uart_ws_url_len,
                                 frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_DOWN_TEXT_DATA) {
        UartLinkHandleDownTextFrame(frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_DOWN_AUDIO_DATA_START) {
        UartLinkHandleDownAudioStartFrame(frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_DOWN_AUDIO_DATA_STOP) {
        UartLinkHandleDownAudioStopFrame(frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_DOWN_AUDIO_DATA) {
        UartLinkHandleDownAudioFrame(frame);
        return;
    }

    esp_rom_printf("[OHOS-S47E] rx frame cmd=0x%04x name=%s len=%u frameCnt=%u\n",
                   frame->cmd_type,
                   OhosUartProtoCmdName(frame->cmd_type),
                   frame->payload_len,
                   g_uart_rx_frame_count);
}

static uint32_t UartLinkParseBufferedStream(uint8_t *stream, uint16_t *streamLen, const char *tag)
{
    uint32_t parsed = 0;

    if (stream == NULL || streamLen == NULL) {
        return 0;
    }

    while (*streamLen >= OHOS_UART_PROTO_FRAME_FIXED_LEN) {
        uint16_t frameOffset = 0;
        uint16_t frameLen = 0;
        OhosUartProtoFrame frame;
        uint32_t audioEnqueuedBefore;
        uint32_t shouldLogFrame;
        int ret = OhosUartProtoFindFrame(stream,
                                         *streamLen,
                                         &frameOffset,
                                         &frameLen,
                                         &frame,
                                         0);

        if (ret == OHOS_UART_PROTO_OK) {
            uint16_t consumeLen = (uint16_t)(frameOffset + frameLen);

            shouldLogFrame = (frame.cmd_type != OHOS_UART_CMD_DOWN_AUDIO_DATA ||
                              g_uart_down_audio_count < 3U ||
                              ((g_uart_down_audio_count + 1U) % 100U) == 0U);
            if (shouldLogFrame) {
                esp_rom_printf("[%s] parse ok offset=%u frameLen=%u cmd=0x%04x name=%s payloadLen=%u\n",
                               tag ? tag : "WS63-UART-PARSE",
                               frameOffset,
                               frameLen,
                               frame.cmd_type,
                               OhosUartProtoCmdName(frame.cmd_type),
                               frame.payload_len);
            }

            audioEnqueuedBefore = g_uart_down_audio_enqueued_hint;
            UartLinkHandleRxFrame(&frame);
            parsed++;

            if (consumeLen < *streamLen) {
                memmove(stream, &stream[consumeLen], *streamLen - consumeLen);
                *streamLen = (uint16_t)(*streamLen - consumeLen);
            } else {
                *streamLen = 0;
            }

            if (frame.cmd_type == OHOS_UART_CMD_DOWN_AUDIO_DATA &&
                g_uart_down_audio_enqueued_hint != audioEnqueuedBefore &&
                (parsed % OHOS_UART_PARSE_AUDIO_YIELD_EVERY) == 0U) {
                LOS_TaskDelay(1);
            }
            continue;
        }

        if (ret == OHOS_UART_PROTO_ERR_SHORT) {
            if (frameOffset > 0U && frameOffset < *streamLen) {
                memmove(stream, &stream[frameOffset], *streamLen - frameOffset);
                *streamLen = (uint16_t)(*streamLen - frameOffset);
            }
            break;
        }

        {
            uint16_t keep = UartLinkKeepPartialHead(stream, *streamLen);
            g_uart_rx_parse_fail_count++;
            esp_rom_printf("[%s] failCnt=%u ret=%d streamLen=%u keep=%u\n",
                           tag ? tag : "WS63-UART-PARSE",
                           g_uart_rx_parse_fail_count,
                           ret,
                           *streamLen,
                           keep);
            UartLinkDumpHex("[WS63-UART-BUF]", stream, *streamLen);

            if (keep > 0U) {
                memmove(stream, &stream[*streamLen - keep], keep);
            }
            *streamLen = keep;
        }
        break;
    }

    return parsed;
}

#if OHOS_UART_LINK_ENABLE_LONG_FRAME_SELFTEST
static uint32_t UartLinkSelftestFeedFrame(uint8_t *stream,
                                          uint16_t *streamLen,
                                          uint16_t cmdType,
                                          const uint8_t *payload,
                                          uint16_t payloadLen,
                                          uint16_t chunk)
{
    uint8_t *frame = g_uart_selftest_frame;
    uint16_t frameLen = 0;
    uint16_t offset = 0;
    uint32_t parsed = 0;
    int ret;

    ret = OhosUartProtoEncode(cmdType,
                              payload,
                              payloadLen,
                              frame,
                              (uint16_t)(OHOS_UART_PROTO_FRAME_FIXED_LEN + 384U),
                              &frameLen,
                              0);
    if (ret != OHOS_UART_PROTO_OK) {
        esp_rom_printf("[WS63-UART-LONG-SELFTEST] encode fail cmd=0x%04x payloadLen=%u ret=%d\n",
                       cmdType,
                       payloadLen,
                       ret);
        return 0;
    }

    while (offset < frameLen) {
        uint16_t part = (uint16_t)(frameLen - offset);
        if (part > chunk) {
            part = chunk;
        }

        if ((uint32_t)(*streamLen + part) > OHOS_UART_RX_STREAM_CAP) {
            esp_rom_printf("[WS63-UART-LONG-SELFTEST] stream overflow cmd=0x%04x streamLen=%u part=%u\n",
                           cmdType,
                           *streamLen,
                           part);
            *streamLen = 0;
            return parsed;
        }

        memcpy(&stream[*streamLen], &frame[offset], part);
        *streamLen = (uint16_t)(*streamLen + part);
        parsed += UartLinkParseBufferedStream(stream, streamLen, "WS63-UART-LONG-SELFTEST");
        offset = (uint16_t)(offset + part);
    }

    esp_rom_printf("[WS63-UART-LONG-SELFTEST] cmd=0x%04x name=%s payloadLen=%u frameLen=%u chunk=%u parsed=%u remain=%u\n",
                   cmdType,
                   OhosUartProtoCmdName(cmdType),
                   payloadLen,
                   frameLen,
                   chunk,
                   parsed,
                   *streamLen);
    return parsed;
}

