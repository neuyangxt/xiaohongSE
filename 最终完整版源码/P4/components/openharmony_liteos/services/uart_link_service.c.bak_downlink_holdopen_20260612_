uint32_t OhosUartLinkUiSetInterruptMode(uint32_t enabled)
{
    uint8_t payload[1] = {0};
    uint32_t mode = enabled ? 1U : 0U;

    payload[0] = (uint8_t)mode;

    if (!g_uart_driver_init_ok) {
        uint32_t initOk = UartLinkDriverInit();
        esp_rom_printf("[S69C-WS63-UI] interrupt force driver init ret=%u driverInit=%u\n",
                       initOk,
                       g_uart_driver_init_ok);
    }

    if (!g_uart_driver_init_ok) {
        esp_rom_printf("[S69C-WS63-UI] interrupt skipped: driver not init mode=%u\n", mode);
        return 0;
    }

    g_uart_interrupt_mode = mode;
    uint32_t txOk = UartLinkSendProtocolFrame(OHOS_UART_CMD_SET_INTERRUPT_MODE,
                                              payload,
                                              sizeof(payload),
                                              "UI_SET_INTERRUPT_MODE");
    g_uart_interrupt_mode_tx_count++;
    if (txOk) {
        g_uart_interrupt_mode_tx_ok++;
    }

    esp_rom_printf("[WS63-UART-INTERRUPT] tx SET_INTERRUPT_MODE mode=%u ok=%u tx=%u/%u agent=%u %s\n",
                   mode,
                   txOk,
                   g_uart_interrupt_mode_tx_ok,
                   g_uart_interrupt_mode_tx_count,
                   g_uart_agent_status,
                   UartLinkAgentStatusName(g_uart_agent_status));

    return txOk;
}

uint32_t OhosUartLinkUiStartUplinkOpusTest(void)
{
    if (!g_uart_driver_init_ok) {
        uint32_t initOk = UartLinkDriverInit();
        esp_rom_printf("[S69C-WS63-UI] uplink opus force driver init ret=%u driverInit=%u\n",
                       initOk,
                       g_uart_driver_init_ok);
    }

    UartLinkUplinkOpusStartTask();

    if (!g_uart_driver_init_ok || !g_uart_link_ready || g_uart_up_opus_task_id == 0U) {
        esp_rom_printf("[S69C-WS63-UI] uplink opus start skipped driver=%u linkReady=%u taskId=%u\n",
                       g_uart_driver_init_ok,
                       g_uart_link_ready,
                       g_uart_up_opus_task_id);
        return 0;
    }

    int32_t encInitRet = OhosOpusEncoderInit();
    if (encInitRet != 0) {
        esp_rom_printf("[S69C-WS63-UI] uplink opus start encoder init fail ret=%ld\n",
                       (long)encInitRet);
        return 0;
    }

    if (!P4AudioStateTryStartUplink("ui_start_uplink")) {
        esp_rom_printf("[S69C-WS63-UI] uplink opus start rejected by audio state=%s\n",
                       P4AudioStateName(g_p4_audio_state));
        return 0;
    }

    g_uart_downlink_preempt_stop_pending = 0;
    OhosAudioEs7210ClearPcmStopForDownlink();
    g_uart_up_opus_stop_req = 0;
    g_uart_up_opus_running = 1;
    g_uart_up_opus_capture_started = 0;
    g_uart_up_opus_session_start_ms = (uint32_t)esp_log_timestamp();
    g_uart_up_opus_session_tx_base = g_uart_up_opus_tx_ok;
    g_uart_up_opus_session_pcm_fail_base = g_uart_up_opus_pcm_fail;
    g_uart_up_opus_session_underflow = 0;
    g_uart_up_opus_start_count++;

    esp_rom_printf("[S69C-WS63-UI] uplink opus start ok startCnt=%u frameMs=%u pcmSamples=%u targetBytes=%u linkReady=%u capStart=%u capWait=%u\n",
                   g_uart_up_opus_start_count,
                   OHOS_OPUS_UPLINK_FRAME_MS,
                   OHOS_OPUS_UPLINK_PCM_SAMPLES,
                   OHOS_OPUS_UPLINK_TARGET_BYTES,
                   g_uart_link_ready,
                   OHOS_UART_UP_OPUS_CAPTURE_START_LEVEL,
                   OHOS_UART_UP_OPUS_CAPTURE_START_MAX_MS);
    return 1;
}

uint32_t OhosUartLinkUiStopUplinkOpusTest(void)
{
    if (!g_uart_up_opus_running) {
        esp_rom_printf("[S69C-WS63-UI] uplink opus stop skipped: not running\n");
        return 1;
    }

    P4AudioStateSet(P4_AUDIO_STATE_UPLINK_STOPPING, "ui_stop_uplink");
    g_uart_up_opus_stop_req = 1;
    g_uart_up_opus_stop_count++;
    esp_rom_printf("[S69C-WS63-UI] uplink opus stop requested stopCnt=%u txOk=%u txFail=%u encOk=%u encFail=%u\n",
                   g_uart_up_opus_stop_count,
                   g_uart_up_opus_tx_ok,
                   g_uart_up_opus_tx_fail,
                   g_uart_up_opus_encode_ok,
                   g_uart_up_opus_encode_fail);
    return 1;
}

