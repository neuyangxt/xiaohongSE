static uint32_t UartLinkDriverInit(void)
{
    if (g_uart_driver_init_ok) {
        uart_config_t uart_config = {
            .baud_rate = OHOS_UART_LINK_BAUDRATE,
            .data_bits = UART_DATA_8_BITS,
            .parity = UART_PARITY_DISABLE,
            .stop_bits = UART_STOP_BITS_1,
            .flow_ctrl = UART_HW_FLOWCTRL_DISABLE,
            .rx_flow_ctrl_thresh = 0,
            .source_clk = UART_SCLK_PLL_F80M,
        };

        esp_err_t paramRet = uart_param_config(OHOS_UART_LINK_PORT, &uart_config);
        esp_err_t baudRet = uart_set_baudrate(OHOS_UART_LINK_PORT, OHOS_UART_LINK_BAUDRATE);
        esp_err_t pinRet = uart_set_pin(OHOS_UART_LINK_PORT,
                                        OHOS_UART_LINK_TX_GPIO, OHOS_UART_LINK_RX_GPIO,
                                        UART_PIN_NO_CHANGE,
                                        UART_PIN_NO_CHANGE);
        uart_flush_input(OHOS_UART_LINK_PORT);
        UartLinkDumpClockDiag("already_installed_reassert");
        g_uart_driver_init_ok = (paramRet == ESP_OK && baudRet == ESP_OK && pinRet == ESP_OK);
        esp_rom_printf("[OHOS-S46A] UartLinkService driver already installed reassert baud=%u paramRet=%d baudRet=%d pinRet=%d initOk=%u\n",
                       OHOS_UART_LINK_BAUDRATE,
                       paramRet,
                       baudRet,
                       pinRet,
                       g_uart_driver_init_ok);
        return g_uart_driver_init_ok;
    }

    uart_config_t uart_config = {
        .baud_rate = OHOS_UART_LINK_BAUDRATE,
        .data_bits = UART_DATA_8_BITS,
        .parity = UART_PARITY_DISABLE,
        .stop_bits = UART_STOP_BITS_1,
        .flow_ctrl = UART_HW_FLOWCTRL_DISABLE,
        .rx_flow_ctrl_thresh = 0,
        .source_clk = UART_SCLK_PLL_F80M,
    };

    UartLinkDumpClockDiag("before_param_config");
    esp_err_t paramRet = uart_param_config(OHOS_UART_LINK_PORT, &uart_config);
    UartLinkDumpClockDiag("after_param_config");
    esp_rom_printf("[WS63-UART-DIAG] config: baud=%u source=PLL_F80M TX=GPIO30 RX=GPIO31 8N1 no-flow\n",
                   (uint32_t)OHOS_UART_LINK_BAUDRATE);
    esp_err_t pinRet = uart_set_pin(OHOS_UART_LINK_PORT,
                                    OHOS_UART_LINK_TX_GPIO, OHOS_UART_LINK_RX_GPIO,
                                    UART_PIN_NO_CHANGE,
                                    UART_PIN_NO_CHANGE);

    esp_err_t installRet = uart_driver_install(OHOS_UART_LINK_PORT,
                                               OHOS_UART_LINK_RX_BUF_SIZE,
                                               OHOS_UART_LINK_TX_BUF_SIZE,
                                               0,
                                               NULL,
                                               0);
    if (installRet == ESP_OK) {
        esp_err_t baudRet = uart_set_baudrate(OHOS_UART_LINK_PORT, OHOS_UART_LINK_BAUDRATE);
        esp_rom_printf("[P4-UART-CLK] post install baud reassert ret=%d\n", baudRet);
    }

    uart_flush_input(OHOS_UART_LINK_PORT);
    UartLinkDumpClockDiag("after_driver_install");

    g_uart_driver_init_ok = (paramRet == ESP_OK &&
                             pinRet == ESP_OK &&
                             installRet == ESP_OK);

    esp_rom_printf("[OHOS-S46A] UartLinkService driver init uart=%d tx=%d rx=%d baud=%u paramRet=%d pinRet=%d installRet=%d initOk=%u\n",
                   OHOS_UART_LINK_PORT,
                   OHOS_UART_LINK_TX_GPIO,
                   OHOS_UART_LINK_RX_GPIO,
                   OHOS_UART_LINK_BAUDRATE,
                   paramRet,
                   pinRet,
                   installRet,
                   g_uart_driver_init_ok);

    return g_uart_driver_init_ok;
}

static uint32_t UartLinkLoopbackTest(void)
{
    const char *tx = "OHOS_UART_LOOPBACK_S46A";
    char rx[64] = {0};

    uart_flush_input(OHOS_UART_LINK_PORT);

    g_uart_write_ret = uart_write_bytes(OHOS_UART_LINK_PORT, tx, strlen(tx));

    /*
     * Give UART enough time to transmit and receive through external TX-RX jumper.
     */
    LOS_TaskDelay(10);

    g_uart_read_ret = esp_rom_printf("[WS63-UART-DIAG] rx task loop alive, waiting bytes...\n");
        uart_read_bytes(OHOS_UART_LINK_PORT,
                                      rx,
                                      sizeof(rx) - 1,
                                      50);

    if (g_uart_read_ret > 0) {
        rx[g_uart_read_ret] = '\0';
    }

    g_uart_loopback_ok = (g_uart_write_ret == (int32_t)strlen(tx) &&
                          g_uart_read_ret == (int32_t)strlen(tx) &&
                          strcmp(tx, rx) == 0);

    esp_rom_printf("[OHOS-S46A] UartLinkService loopback write=%d read=%d tx=\"%s\" rx=\"%s\" loopOk=%u\n",
                   g_uart_write_ret,
                   g_uart_read_ret,
                   tx,
                   rx,
                   g_uart_loopback_ok);

    return g_uart_loopback_ok;
}


static void UartLinkDumpHex(const char *tag, const uint8_t *data, uint16_t len)
{
    const char *name = tag ? tag : "[WS63-UART-HEX]";
    uint16_t dumpLen = (len > 96U) ? 96U : len;

    if (data == NULL) {
        esp_rom_printf("%s len=%u data=null\n", name, len);
        return;
    }

    esp_rom_printf("%s len=%u data=", name, len);

    for (uint16_t i = 0; i < dumpLen; ++i) {
        esp_rom_printf("%02X", data[i]);
        if ((uint16_t)(i + 1U) < dumpLen) {
            esp_rom_printf(" ");
        }
    }

    if (len > dumpLen) {
        esp_rom_printf(" ...");
    }

    esp_rom_printf("\n");
}

static uint16_t UartLinkReadLe16(const uint8_t *p)
{
    return (uint16_t)p[0] | ((uint16_t)p[1] << 8);
}

static uint16_t UartLinkSafeCopyText(char *dst, uint16_t dstCap, const uint8_t *src, uint16_t srcLen)
{
    uint16_t copyLen;

    if (dst == NULL || dstCap == 0U) {
        return 0;
    }

    copyLen = srcLen;
    if (copyLen >= dstCap) {
        copyLen = (uint16_t)(dstCap - 1U);
    }

    if (copyLen > 0U && src != NULL) {
        memcpy(dst, src, copyLen);
    }
    dst[copyLen] = '\0';
    return copyLen;
}

static uint16_t UartLinkKeepPartialHead(const uint8_t *stream, uint16_t streamLen)
{
    static const uint8_t head[4] = {0xA5, 0xA5, 0x5A, 0x5A};
    uint16_t maxKeep = (streamLen < 3U) ? streamLen : 3U;

    for (uint16_t keep = maxKeep; keep > 0U; --keep) {
        if (memcmp(&stream[streamLen - keep], head, keep) == 0) {
            return keep;
        }
    }

    return 0;
}

static void UartLinkHandleStringData(const char *tag,
                                     char *cache,
                                     uint16_t cacheCap,
                                     volatile uint32_t *cachedLen,
                                     const OhosUartProtoFrame *frame)
{
    uint16_t copyLen;

    if (frame == NULL || cache == NULL || cachedLen == NULL) {
        return;
    }

    copyLen = UartLinkSafeCopyText(cache, cacheCap, frame->payload, frame->payload_len);
    *cachedLen = frame->payload_len;

    esp_rom_printf("[WS63-UART-DATA] %s cmd=0x%04x payloadLen=%u cachedLen=%u text=\"%s\"\n",
                   tag ? tag : OhosUartProtoCmdName(frame->cmd_type),
                   frame->cmd_type,
                   frame->payload_len,
                   copyLen,
                   cache);
}

static void UartLinkHandleDownTextFrame(const OhosUartProtoFrame *frame)
{
    uint32_t textType;
    uint16_t textLen;
    uint16_t available;
    uint16_t copyLen;

    if (frame == NULL || frame->payload == NULL || frame->payload_len < 3U) {
        g_uart_rx_parse_fail_count++;
        esp_rom_printf("[WS63-UART-DOWN-TEXT] invalid payloadLen=%u failCnt=%u\n",
                       frame ? frame->payload_len : 0U,
                       g_uart_rx_parse_fail_count);
        return;
    }

    textType = frame->payload[0];
    textLen = UartLinkReadLe16(&frame->payload[1]);
    available = (uint16_t)(frame->payload_len - 3U);

    if (textLen > available) {
        g_uart_rx_parse_fail_count++;
        esp_rom_printf("[WS63-UART-DOWN-TEXT] length mismatch type=%u textLen=%u available=%u payloadLen=%u failCnt=%u\n",
                       textType,
                       textLen,
                       available,
                       frame->payload_len,
                       g_uart_rx_parse_fail_count);
        return;
    }

    copyLen = UartLinkSafeCopyText(g_uart_down_text,
                                   OHOS_UART_TEXT_CACHE_CAP,
                                   &frame->payload[3],
                                   textLen);
    g_uart_down_text_type = textType;
    g_uart_down_text_len = textLen;
    g_uart_down_text_count++;
    (void)P4AudioRequestDownlinkPreemptUplink("down_text");

    esp_rom_printf("[WS63-UART-DOWN-TEXT] count=%u cmd=0x%04x payloadLen=%u type=%u textLen=%u cachedLen=%u text=\"%s\"\n",
                   g_uart_down_text_count,
                   frame->cmd_type,
                   frame->payload_len,
                   textType,
                   textLen,
                   copyLen,
                   g_uart_down_text);
}

static void UartLinkOpusQueueEnqueue(const uint8_t *data, uint16_t len)
{
    uint32_t intSave;
    uint32_t slot;
    uint32_t qAfter = 0;
    uint32_t capacity = g_uart_opus_queue_capacity;

    if (data == NULL || len == 0U) {
        return;
    }

    if (g_uart_opus_queue == NULL || capacity == 0U) {
        UartLinkOpusQueueInit();
        capacity = g_uart_opus_queue_capacity;
        if (g_uart_opus_queue == NULL || capacity == 0U) {
            g_uart_opus_drop_count++;
            esp_rom_printf("[WS63-UART-OPUS] drop queue unavailable len=%u drop=%u\n",
                           len,
                           g_uart_opus_drop_count);
            return;
        }
    }

    uint32_t nowMs = (uint32_t)esp_log_timestamp();
    g_uart_down_audio_last_rx_ms = nowMs;
    if (g_uart_down_audio_first_frame_ms == 0U) {
        g_uart_down_audio_first_frame_ms = nowMs;
        esp_rom_printf("[P4-DOWNLINK-TIMING] first 0x0E41 seq=%u startDelay=%u prepared=%u q=%u len=%u\n",
                       g_uart_downlink_session_seq,
                       g_uart_down_audio_last_start_ms ?
                       (uint32_t)(nowMs - g_uart_down_audio_last_start_ms) : 0U,
                       g_uart_downlink_session_prepared_seq,
                       g_uart_opus_queue_count,
                       len);
    }
    if (g_uart_opus_queue_count == 0U && g_p4_audio_state != P4_AUDIO_STATE_DOWNLINK_PLAYING) {
        g_uart_down_audio_prefill_start_ms = nowMs;
        if (g_uart_down_audio_explicit_start_pending) {
            g_uart_down_audio_explicit_start_pending = 0U;
        } else {
            g_uart_downlink_session_seq++;
            g_uart_down_audio_boundary_active = 1U;
            g_uart_down_audio_stop_seen = 0U;
        }
    }

    if (len > OHOS_UART_OPUS_QUEUE_FRAME_MAX) {
        g_uart_opus_drop_count++;
        esp_rom_printf("[WS63-UART-OPUS] drop oversize len=%u max=%u drop=%u\n",
                       len,
                       OHOS_UART_OPUS_QUEUE_FRAME_MAX,
                       g_uart_opus_drop_count);
        return;
    }

    intSave = LOS_IntLock();
    if (g_uart_opus_queue_count >= capacity) {
        g_uart_opus_drop_count++;
        g_uart_opus_queue_full_drop++;
        qAfter = g_uart_opus_queue_count;
        LOS_IntRestore(intSave);
        if (g_uart_opus_queue_full_drop <= 10U ||
            (g_uart_opus_queue_full_drop % 20U) == 0U) {
            esp_rom_printf("[WS63-UART-OPUS] drop queue full len=%u q=%u drop=%u fullDrop=%u\n",
                           len,
                           qAfter,
                           g_uart_opus_drop_count,
                           g_uart_opus_queue_full_drop);
        }
        return;
    }

    slot = g_uart_opus_write_idx;
    memcpy(g_uart_opus_queue[slot].data, data, len);
    g_uart_opus_queue[slot].len = len;
    g_uart_opus_write_idx = (g_uart_opus_write_idx + 1U) % capacity;
    g_uart_opus_queue_count++;
    g_uart_opus_enqueue_count++;
    g_uart_opus_last_len = len;
    qAfter = g_uart_opus_queue_count;
    LOS_IntRestore(intSave);

    if (g_uart_opus_enqueue_count <= 3U || (g_uart_opus_enqueue_count % 100U) == 0U) {
        esp_rom_printf("[WS63-UART-OPUS] enqueue len=%u q=%u enq=%u drop=%u fullDrop=%u semReady=%u session=%u prepared=%u\n",
                       len,
                       qAfter,
                       g_uart_opus_enqueue_count,
                       g_uart_opus_drop_count,
                       g_uart_opus_queue_full_drop,
                       g_uart_opus_sem_ready,
                       g_uart_downlink_session_seq,
                       g_uart_downlink_session_prepared_seq);
    }

    if (g_uart_opus_sem_ready &&
        (g_p4_audio_state == P4_AUDIO_STATE_DOWNLINK_PLAYING ||
         qAfter >= OHOS_UART_DOWNLINK_PREFILL_FRAMES)) {
        (void)LOS_SemPost(g_uart_opus_sem);
    }
}

static uint16_t UartLinkTrimZeroTailToSplitLen(const uint8_t *data, uint16_t len)
{
    uint16_t trimmed = len;

    if (data == NULL || len <= OHOS_UART_DOWN_AUDIO_DIRECT_MAX) {
        return len;
    }

    while (trimmed > OHOS_UART_DOWN_AUDIO_DIRECT_MAX && data[trimmed - 1U] == 0U) {
        trimmed--;
    }

    if (trimmed >= OHOS_UART_DOWN_AUDIO_SPLIT_UNIT &&
        (trimmed % OHOS_UART_DOWN_AUDIO_SPLIT_UNIT) == 0U) {
        return trimmed;
    }

    return len;
}

static uint32_t UartLinkDownAudioValidateAndEnqueue(const uint8_t *data, uint16_t len, const char *src)
{
    OhosOpusPacketInfo info;
    int32_t preRet;

    preRet = OhosOpusValidatePacket(data, len, &info);
    if (preRet != 0 || !info.valid) {
        g_uart_opus_drop_count++;
        g_uart_opus_precheck_fail++;
        if (g_uart_opus_precheck_fail <= 10U ||
            (g_uart_opus_precheck_fail % 20U) == 0U) {
            esp_rom_printf("[WS63-UART-DOWN-AUDIO] drop invalid opus src=%s len=%u frames=%ld samples=%ld ch=%ld err=%ld preOk=%u preFail=%u drop=%u state=%s\n",
                           src ? src : "-",
                           len,
                           (long)info.frames,
                           (long)info.samples,
                           (long)info.channels,
                           (long)info.error,
                           g_uart_opus_precheck_ok,
                           g_uart_opus_precheck_fail,
                           g_uart_opus_drop_count,
                           P4AudioStateName(g_p4_audio_state));
        }
        return 0;
    }

    g_uart_opus_precheck_ok++;
    if (g_uart_opus_precheck_ok <= 3U ||
        (g_uart_opus_precheck_ok % 100U) == 0U ||
        info.samples != 960) {
        esp_rom_printf("[WS63-UART-DOWN-AUDIO] opus precheck ok src=%s len=%u frames=%ld samples=%ld spf=%ld ch=%ld preOk=%u q=%u state=%s\n",
                       src ? src : "-",
                       len,
                       (long)info.frames,
                       (long)info.samples,
                       (long)info.samples_per_frame,
                       (long)info.channels,
                       g_uart_opus_precheck_ok,
                       g_uart_opus_queue_count,
                       P4AudioStateName(g_p4_audio_state));
    }

    UartLinkOpusQueueEnqueue(data, len);
    g_uart_down_audio_enqueued_hint++;
    return 1;
}

static void UartLinkHandleDownAudioPayload(const uint8_t *data, uint16_t len)
{
    uint16_t effectiveLen;

    if (data == NULL || len == 0U) {
        g_uart_opus_drop_count++;
        esp_rom_printf("[WS63-UART-DOWN-AUDIO] drop empty payload len=%u drop=%u\n",
                       len,
                       g_uart_opus_drop_count);
        return;
    }

    if (P4AudioStateIsUplinkBusy(g_p4_audio_state)) {
        (void)P4AudioRequestDownlinkPreemptUplink("down_audio");
    }

    if (len <= OHOS_UART_DOWN_AUDIO_DIRECT_MAX) {
        (void)UartLinkDownAudioValidateAndEnqueue(data, len, "direct");
        return;
    }

    effectiveLen = UartLinkTrimZeroTailToSplitLen(data, len);
    if ((effectiveLen % OHOS_UART_DOWN_AUDIO_SPLIT_UNIT) == 0U) {
        uint16_t offset = 0;
        uint16_t frames = (uint16_t)(effectiveLen / OHOS_UART_DOWN_AUDIO_SPLIT_UNIT);

        esp_rom_printf("[WS63-UART-DOWN-AUDIO] split concatenated payload len=%u effective=%u frames=%u unit=%u\n",
                       len,
                       effectiveLen,
                       frames,
                       OHOS_UART_DOWN_AUDIO_SPLIT_UNIT);

        while (offset < effectiveLen) {
            (void)UartLinkDownAudioValidateAndEnqueue(&data[offset],
                                                      OHOS_UART_DOWN_AUDIO_SPLIT_UNIT,
                                                      "split");
            offset = (uint16_t)(offset + OHOS_UART_DOWN_AUDIO_SPLIT_UNIT);
        }
        return;
    }

    g_uart_opus_drop_count++;
    esp_rom_printf("[WS63-UART-DOWN-AUDIO] drop suspicious payload len=%u effective=%u directMax=%u unit=%u drop=%u\n",
                   len,
                   effectiveLen,
                   OHOS_UART_DOWN_AUDIO_DIRECT_MAX,
                   OHOS_UART_DOWN_AUDIO_SPLIT_UNIT,
                   g_uart_opus_drop_count);
}

static uint16_t UartLinkOpusQueuePop(uint8_t *out, uint16_t outCap)
{
    uint32_t intSave;
    uint32_t slot;
    uint32_t capacity = g_uart_opus_queue_capacity;
    uint16_t len;

    if (out == NULL || outCap == 0U) {
        return 0;
    }

    if (g_uart_opus_queue == NULL || capacity == 0U) {
        return 0;
    }

    intSave = LOS_IntLock();
    if (g_uart_opus_queue_count == 0U) {
        LOS_IntRestore(intSave);
        return 0;
    }

    slot = g_uart_opus_read_idx;
    len = g_uart_opus_queue[slot].len;
    if (len > outCap) {
        len = outCap;
    }
    memcpy(out, g_uart_opus_queue[slot].data, len);
    g_uart_opus_read_idx = (g_uart_opus_read_idx + 1U) % capacity;
    g_uart_opus_queue_count--;
    g_uart_opus_pop_count++;
    LOS_IntRestore(intSave);

    return len;
}

static UartLinkOpusFrameTrace *UartLinkOpusTraceBegin(uint16_t len,
                                                      uint32_t state,
                                                      uint32_t qBefore,
                                                      const OhosOpusPacketInfo *info,
                                                      int32_t preRet)
{
    uint32_t slot;
    UartLinkOpusFrameTrace *trace;

    slot = g_uart_opus_history_idx % OHOS_UART_OPUS_HISTORY_DEPTH;
    g_uart_opus_history_idx++;
    trace = &g_uart_opus_history[slot];
    memset(trace, 0, sizeof(*trace));
    trace->seq = ++g_uart_opus_trace_seq;
    trace->len = len;
    trace->q_before = (uint16_t)qBefore;
    trace->q_after = (uint16_t)g_uart_opus_queue_count;
    trace->state = state;
    if (info != NULL) {
        trace->pre_frames = info->frames;
        trace->pre_samples = info->samples;
        trace->pre_error = info->error;
    } else {
        trace->pre_error = preRet;
    }
    trace->dec_ret = 0x7fffffff;
    trace->play_ret = 0xffffffffU;
    return trace;
}

static void UartLinkOpusDumpRecentHistory(const char *reason)
{
    uint32_t total = (g_uart_opus_history_idx < OHOS_UART_OPUS_HISTORY_DEPTH) ?
                     g_uart_opus_history_idx : OHOS_UART_OPUS_HISTORY_DEPTH;
    uint32_t start = (g_uart_opus_history_idx >= total) ?
                     (g_uart_opus_history_idx - total) : 0U;

    esp_rom_printf("[WS63-UART-OPUS-HIST] reason=%s total=%u idx=%u q=%u drop=%u preOk=%u preFail=%u fullDrop=%u\n",
                   reason ? reason : "-",
                   total,
                   g_uart_opus_history_idx,
                   g_uart_opus_queue_count,
                   g_uart_opus_drop_count,
                   g_uart_opus_precheck_ok,
                   g_uart_opus_precheck_fail,
                   g_uart_opus_queue_full_drop);

    for (uint32_t n = 0; n < total; ++n) {
        const UartLinkOpusFrameTrace *trace =
            &g_uart_opus_history[(start + n) % OHOS_UART_OPUS_HISTORY_DEPTH];
        esp_rom_printf("[WS63-UART-OPUS-HIST] seq=%u len=%u q=%u/%u state=%s preFrames=%ld preSamples=%ld preErr=%ld decRet=%ld decSamples=%u playRet=%u\n",
                       trace->seq,
                       trace->len,
                       trace->q_before,
                       g_uart_opus_queue_capacity,
                       P4AudioStateName(trace->state),
                       (long)trace->pre_frames,
                       (long)trace->pre_samples,
                       (long)trace->pre_error,
                       (long)trace->dec_ret,
                       trace->dec_samples,
                       trace->play_ret);
    }
}

static VOID *UartLinkPcmPlaybackTask(UINT32 arg)
{
