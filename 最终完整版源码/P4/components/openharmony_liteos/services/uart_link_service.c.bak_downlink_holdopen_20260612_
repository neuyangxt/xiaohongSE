    esp_rom_printf("[S69C-WS63-UI] send query txOk=%u queryCnt=%u queryOk=%u linkReady=%u\n",
                   txOk,
                   g_uart_query_tx_count,
                   g_uart_query_tx_ok,
                   g_uart_link_ready);

    return txOk;
}

