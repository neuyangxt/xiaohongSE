    uint32_t txOk = UartLinkSendProtocolFrame(OHOS_UART_CMD_QUERY_SYSTEM_STATUS,
                                              NULL,
                                              0,
                                              "UI_QUERY_SYSTEM_STATUS");
    g_uart_query_tx_count++;
    if (txOk) {
        g_uart_query_tx_ok++;
