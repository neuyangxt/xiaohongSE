static uint32_t UartLinkSendProtocolFrame(uint16_t cmdType,
                                          const uint8_t *payload,
                                          uint16_t payloadLen,
                                          const char *tag)
{
    uint8_t *frame = g_uart_tx_frame;
    uint16_t frameLen = 0;
    int encodeRet;
    int writeRet;
    uint32_t ok;

    if (payloadLen > OHOS_UART_PROTO_MAX_PAYLOAD_LEN) {
        esp_rom_printf("[OHOS-S47H] tx frame tag=%s cmd=0x%04x payload too large len=%u\n",
                       tag ? tag : "null",
                       cmdType,
                       payloadLen);
        return 0;
    }

    encodeRet = OhosUartProtoEncode(cmdType,
                                    payload,
                                    payloadLen,
                                    frame,
                                    OHOS_UART_PROTO_MAX_FRAME_LEN,
                                    &frameLen,
                                    0);

    if (encodeRet != OHOS_UART_PROTO_OK) {
        esp_rom_printf("[OHOS-S47H] tx frame tag=%s cmd=0x%04x encodeRet=%d ok=0\n",
                       tag ? tag : "null",
                       cmdType,
                       encodeRet);
        return 0;
    }

    writeRet = uart_write_bytes(OHOS_UART_LINK_PORT, frame, frameLen);
    ok = (writeRet == (int)frameLen);
    g_uart_diag_tx_count++;

    esp_rom_printf("[WS63-UART-TX] cnt=%u tag=%s cmd=0x%04x name=%s payloadLen=%u frameLen=%u writeRet=%d ok=%u\n",
                   g_uart_diag_tx_count,
                   tag ? tag : "null",
                   cmdType,
                   OhosUartProtoCmdName(cmdType),
                   payloadLen,
                   frameLen,
                   writeRet,
                   ok);
    UartLinkDumpHex("[WS63-UART-TX-RAW]", frame, frameLen);

    esp_rom_printf("[OHOS-S47H] tx frame tag=%s cmd=0x%04x name=%s payloadLen=%u frameLen=%u writeRet=%d ok=%u\n",
                   tag ? tag : "null",
                   cmdType,
                   OhosUartProtoCmdName(cmdType),
                   payloadLen,
                   frameLen,
                   writeRet,
                   ok);

    return ok;
}

static uint32_t UartLinkSendUplinkOpusFrame(const uint8_t *payload, uint16_t payloadLen)
{
    uint16_t frameLen = 0;
    int encodeRet;
    int writeRet;
    uint32_t ok;

    encodeRet = OhosUartProtoEncode(OHOS_UART_CMD_UP_AUDIO_DATA,
                                    payload,
                                    payloadLen,
                                    g_uart_up_opus_tx_frame,
                                    (uint16_t)sizeof(g_uart_up_opus_tx_frame),
                                    &frameLen,
                                    0);
    if (encodeRet != OHOS_UART_PROTO_OK) {
        g_uart_up_opus_last_ret = (uint32_t)encodeRet;
        ESP_LOGW("WS63-UART-UP-OPUS",
                 "encode frame fail opusLen=%u ret=%d",
                 payloadLen,
                 encodeRet);
        return 0;
    }

    writeRet = uart_write_bytes(OHOS_UART_LINK_PORT, g_uart_up_opus_tx_frame, frameLen);
    ok = (writeRet == (int)frameLen);
    g_uart_up_opus_last_ret = (uint32_t)writeRet;
    if (ok) {
        g_uart_diag_tx_count++;
    }

    if (!ok ||
        g_uart_up_opus_tx_ok < OHOS_UART_UP_OPUS_FRAME_LOG_FIRST ||
        ((g_uart_up_opus_tx_ok + g_uart_up_opus_tx_fail) % OHOS_UART_UP_OPUS_FRAME_LOG_EVERY) == 0U) {
        ESP_LOGI("WS63-UART-UP-OPUS",
                 "tx cmd=0x%04x payloadLen=%u frameLen=%u writeRet=%d ok=%u txOk=%u txFail=%u linkReady=%u",
                 OHOS_UART_CMD_UP_AUDIO_DATA,
                 payloadLen,
                 frameLen,
                 writeRet,
                 ok,
                 g_uart_up_opus_tx_ok,
                 g_uart_up_opus_tx_fail,
                 g_uart_link_ready);
    }

    return ok;
}

