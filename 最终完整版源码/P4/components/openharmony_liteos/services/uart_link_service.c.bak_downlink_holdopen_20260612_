    g_uart_pcm_play_task_started = 1;
    esp_rom_printf("[WS63-UART-PCM] playback task start prio=%u stack=0x%x ring=%u chunk=%u prefill=%u\n",
                   OHOS_UART_PCM_PLAY_TASK_PRIO,
                   OHOS_UART_PCM_PLAY_TASK_STACK,
                   g_uart_pcm_ring_capacity,
                   OHOS_UART_PCM_PLAY_CHUNK_SAMPLES,
                   OHOS_UART_PCM_PREFILL_SAMPLES);

    (void)OhosAudioEs8311PortStartRealHw();

    while (1) {
        uint32_t level = UartLinkPcmRingLevelSamples();
        uint32_t prefillTarget = g_uart_down_audio_stream_open ?
                                 OHOS_UART_PCM_STREAM_PREFILL_SAMPLES :
                                 OHOS_UART_PCM_PREFILL_SAMPLES;
        if (g_uart_pcm_ring_capacity > 0U &&
            prefillTarget > (g_uart_pcm_ring_capacity / 2U)) {
            prefillTarget = g_uart_pcm_ring_capacity / 2U;
        }
        if (prefillTarget < OHOS_UART_PCM_PLAY_CHUNK_SAMPLES) {
            prefillTarget = OHOS_UART_PCM_PLAY_CHUNK_SAMPLES;
        }

        if (g_p4_audio_state != P4_AUDIO_STATE_DOWNLINK_PLAYING) {
            if (g_uart_pcm_sem_ready) {
                (void)LOS_SemPend(g_uart_pcm_sem, OhosLiteosMsToTicks(10));
            } else {
                LOS_TaskDelay(1);
            }
            continue;
        }

        if (level == 0U && g_uart_downlink_loopback_pad_remaining > 0U) {
            uint32_t padNow = g_uart_downlink_loopback_pad_remaining;
            if (padNow > OHOS_UART_PCM_PLAY_CHUNK_SAMPLES) {
                padNow = OHOS_UART_PCM_PLAY_CHUNK_SAMPLES;
            }
            memset(g_uart_pcm_play_chunk, 0, OHOS_UART_PCM_PLAY_CHUNK_SAMPLES * sizeof(g_uart_pcm_play_chunk[0]));
            g_uart_downlink_loopback_pad_remaining -= padNow;
            g_uart_pcm_play_started_session = 1;
            g_uart_pcm_play_write_busy = 1;
            uint32_t playRet = OhosAudioEs8311PortPlayPcm16MonoDialog(g_uart_pcm_play_chunk,
                                                                      padNow);
            g_uart_pcm_play_write_busy = 0;
            if (playRet == 0U) {
                g_uart_pcm_i2s_write_ok++;
                g_uart_pcm_i2s_samples += padNow;
                g_uart_downlink_played_samples += padNow;
                g_uart_downlink_write_count++;
                if (g_uart_downlink_first_play_ms == 0U) {
                    g_uart_downlink_first_play_ms = (uint32_t)esp_log_timestamp();
                }
            } else {
                g_uart_pcm_i2s_write_fail++;
                esp_rom_printf("[WS63-UART-PCM] loopback pad i2s fail ret=%u remain=%u ok=%u fail=%u\n",
                               playRet,
                               g_uart_downlink_loopback_pad_remaining,
                               g_uart_pcm_i2s_write_ok,
                               g_uart_pcm_i2s_write_fail);
            }
            P4AudioStateFinishDownlinkIfIdle();
            continue;
        }

        if (level == 0U) {
            if (g_p4_audio_state == P4_AUDIO_STATE_DOWNLINK_PLAYING) {
                if (g_uart_down_audio_stream_open && !g_uart_down_audio_stop_seen) {
                    g_uart_down_audio_stream_underrun++;
                }
                P4AudioStateFinishDownlinkIfIdle();
            }
            if (g_uart_pcm_sem_ready) {
                (void)LOS_SemPend(g_uart_pcm_sem, OhosLiteosMsToTicks(10));
            } else {
                LOS_TaskDelay(1);
            }
            continue;
        }

        if (!g_uart_pcm_play_started_session && level < prefillTarget) {
            uint32_t nowMs = (uint32_t)esp_log_timestamp();
            uint32_t startMs = g_uart_pcm_play_prefill_start_ms;
            if (startMs == 0U) {
                g_uart_pcm_play_prefill_start_ms = nowMs;
                startMs = nowMs;
            }
            if (g_uart_opus_queue_count > 0U ||
                g_uart_opus_decode_push_busy ||
                (uint32_t)(nowMs - startMs) < OHOS_UART_PCM_PREFILL_MAX_MS) {
                g_uart_downlink_prefill_wait_ms += 2U;
                LOS_TaskDelay(2);
                continue;
            }
            esp_rom_printf("[WS63-UART-PCM] prefill timeout start level=%u q=%u wait=%u target=%u streamOpen=%u stopSeen=%u\n",
                           level,
                           g_uart_opus_queue_count,
                           (uint32_t)(nowMs - startMs),
                           prefillTarget,
                           g_uart_down_audio_stream_open,
                           g_uart_down_audio_stop_seen);
        }
        g_uart_pcm_play_started_session = 1;

        if (level < OHOS_UART_PCM_PLAY_CHUNK_SAMPLES &&
            (g_uart_opus_queue_count > 0U || g_uart_opus_decode_push_busy)) {
            uint32_t nowMs = (uint32_t)esp_log_timestamp();
            uint32_t startMs = g_uart_pcm_play_block_wait_start_ms;
            if (startMs == 0U) {
                g_uart_pcm_play_block_wait_start_ms = nowMs;
                startMs = nowMs;
            }
            if ((uint32_t)(nowMs - startMs) < OHOS_UART_PCM_BLOCK_FILL_MAX_MS) {
                g_uart_downlink_pcm_wait_ms += 2U;
                LOS_TaskDelay(2);
                continue;
            }
        } else {
            g_uart_pcm_play_block_wait_start_ms = 0;
        }

        uint32_t got = UartLinkPcmRingRead(g_uart_pcm_play_chunk,
                                           OHOS_UART_PCM_PLAY_CHUNK_SAMPLES);
        if (got == 0U) {
            g_uart_pcm_ring_underflow++;
            if (g_uart_pcm_ring_underflow <= 5U ||
                (g_uart_pcm_ring_underflow % 50U) == 0U) {
                esp_rom_printf("[WS63-UART-PCM] underrun q=%u pcm=%u underflow=%u\n",
                               g_uart_opus_queue_count,
                               UartLinkPcmRingLevelSamples(),
                               g_uart_pcm_ring_underflow);
            }
            OhosLiteosDelayMs(2);
            P4AudioStateFinishDownlinkIfIdle();
            continue;
        }
        g_uart_pcm_play_block_wait_start_ms = 0;

        g_uart_pcm_play_write_busy = 1;
        uint32_t playRet = OhosAudioEs8311PortPlayPcm16MonoDialog(g_uart_pcm_play_chunk,
                                                                  got);
        g_uart_pcm_play_write_busy = 0;

        if (playRet == 0U) {
            g_uart_pcm_i2s_write_ok++;
            g_uart_pcm_i2s_samples += got;
            g_uart_downlink_played_samples += got;
            g_uart_downlink_write_count++;
            if (g_uart_downlink_first_play_ms == 0U) {
                g_uart_downlink_first_play_ms = (uint32_t)esp_log_timestamp();
            }
            uint32_t afterLevel = UartLinkPcmRingLevelSamples();
            if (afterLevel < g_uart_downlink_pcm_min_level) {
                g_uart_downlink_pcm_min_level = afterLevel;
            }
            if (afterLevel < g_uart_down_audio_stream_min_level) {
                g_uart_down_audio_stream_min_level = afterLevel;
            }
            if (afterLevel > g_uart_downlink_pcm_max_level) {
                g_uart_downlink_pcm_max_level = afterLevel;
            }
            if (g_uart_down_audio_first_play_ms == 0U) {
                g_uart_down_audio_first_play_ms = (uint32_t)esp_log_timestamp();
                esp_rom_printf("[P4-DOWNLINK-TIMING] first I2S play seq=%u startDelay=%u pcmPushDelay=%u got=%u afterLevel=%u prefillWait=%u pcmWait=%u underrun=%u\n",
                               g_uart_downlink_session_seq,
                               g_uart_down_audio_last_start_ms ?
                               (uint32_t)(g_uart_down_audio_first_play_ms -
                                          g_uart_down_audio_last_start_ms) : 0U,
                               g_uart_down_audio_first_pcm_push_ms ?
                               (uint32_t)(g_uart_down_audio_first_play_ms -
                                          g_uart_down_audio_first_pcm_push_ms) : 0U,
                               got,
                               afterLevel,
                               g_uart_downlink_prefill_wait_ms,
                               g_uart_downlink_pcm_wait_ms,
                               g_uart_down_audio_stream_underrun);
            }
        } else {
            g_uart_pcm_i2s_write_fail++;
            esp_rom_printf("[WS63-UART-PCM] i2s fail ret=%u got=%u level=%u ok=%u fail=%u\n",
                           playRet,
                           got,
                           UartLinkPcmRingLevelSamples(),
                           g_uart_pcm_i2s_write_ok,
                           g_uart_pcm_i2s_write_fail);
        }

        if (g_uart_pcm_i2s_write_ok <= 1U ||
            (g_uart_pcm_i2s_write_ok % 200U) == 0U ||
            got < OHOS_UART_PCM_PLAY_CHUNK_SAMPLES) {
            esp_rom_printf("[WS63-UART-PCM] i2s ok chunk=%u got=%u level=%u q=%u ok=%u samples=%u underrun=%u overflow=%u\n",
                           OHOS_UART_PCM_PLAY_CHUNK_SAMPLES,
                           got,
                           UartLinkPcmRingLevelSamples(),
                           g_uart_opus_queue_count,
                           g_uart_pcm_i2s_write_ok,
                           g_uart_pcm_i2s_samples,
                           g_uart_pcm_ring_underflow,
                           g_uart_pcm_ring_overflow);
        }

        P4AudioStateFinishDownlinkIfIdle();
    }

    return NULL;
}

static void UartLinkPcmPlaybackStartTask(void)
{
    UINT32 semRet;
    UINT32 taskRet;

    (void)UartLinkPcmRingInit();

    if (!g_uart_pcm_sem_ready) {
        semRet = LOS_SemCreate(0, &g_uart_pcm_sem);
        g_uart_pcm_sem_ready = (semRet == LOS_OK);
        esp_rom_printf("[WS63-UART-PCM] sem create ret=%u sem=%u ready=%u\n",
                       semRet,
                       g_uart_pcm_sem,
                       g_uart_pcm_sem_ready);
    }

    if (g_uart_pcm_play_task_id != 0U) {
        return;
    }

    taskRet = UartLinkCreateExternalStackTask("ohos_pcm_play",
                                              (TSK_ENTRY_FUNC)UartLinkPcmPlaybackTask,
                                              0,
                                              OHOS_UART_PCM_PLAY_TASK_PRIO,
                                              OHOS_UART_PCM_PLAY_TASK_STACK,
                                              &g_uart_pcm_play_task_id);
    esp_rom_printf("[WS63-UART-PCM] playback task create ret=%u taskId=%u prio=%u stack=0x%x\n",
                   taskRet,
                   g_uart_pcm_play_task_id,
                   OHOS_UART_PCM_PLAY_TASK_PRIO,
                   OHOS_UART_PCM_PLAY_TASK_STACK);

    if (taskRet != LOS_OK) {
        g_uart_pcm_play_task_id = 0;
    }
}

static VOID *UartLinkOpusPlayTask(UINT32 arg)
{
    (void)arg;

    g_uart_opus_task_started = 1;
    esp_rom_printf("[WS63-UART-OPUS] play task start prio=%u stack=0x%x queueDepth=%u queueFrameMax=%u maxFrame=%u maxSamples=%u\n",
                   OHOS_UART_OPUS_PLAY_TASK_PRIO,
                   OHOS_UART_OPUS_PLAY_TASK_STACK,
                   g_uart_opus_queue_capacity,
                   OHOS_UART_OPUS_QUEUE_FRAME_MAX,
                   OHOS_OPUS_MAX_FRAME_BYTES,
                   OHOS_OPUS_MAX_PCM_SAMPLES);

    (void)OhosOpusDecoderInit();
    (void)OhosAudioEs8311PortStartRealHw();

    while (1) {
        uint16_t opusLen;
        uint32_t qBefore;

        if (g_uart_opus_queue_count == 0U) {
            if (g_uart_down_audio_prepare_pending &&
                g_uart_downlink_session_seq != 0U &&
                g_uart_downlink_session_prepared_seq != g_uart_downlink_session_seq) {
                (void)P4AudioPrepareDownlinkSessionIfNeeded("down_audio_start");
                LOS_TaskDelay(1);
                continue;
            }
            if (g_p4_audio_state == P4_AUDIO_STATE_DOWNLINK_PLAYING) {
                P4AudioStateFinishDownlinkIfIdle();
                LOS_TaskDelay(5);
            } else if (g_uart_opus_sem_ready) {
                (void)LOS_SemPend(g_uart_opus_sem, OhosLiteosMsToTicks(20));
            } else {
                LOS_TaskDelay(1);
            }
        }

        if (g_p4_audio_state != P4_AUDIO_STATE_DOWNLINK_PLAYING &&
            g_uart_opus_queue_count > 0U &&
            g_uart_opus_queue_count < OHOS_UART_DOWNLINK_PREFILL_FRAMES &&
            !g_uart_down_audio_stop_seen) {
            uint32_t nowMs = (uint32_t)esp_log_timestamp();
            uint32_t prefillStartMs = g_uart_down_audio_prefill_start_ms;

            if (prefillStartMs == 0U ||
                (uint32_t)(nowMs - prefillStartMs) < OHOS_UART_DOWNLINK_PREFILL_MAX_MS) {
                LOS_TaskDelay(5);
                continue;
            }
        }

        if (g_uart_opus_queue_count == 0U) {
            continue;
        }

        if (!P4AudioPrepareDownlinkSessionIfNeeded("opus_frame_pop")) {
            LOS_TaskDelay(5);
            continue;
        }

        qBefore = g_uart_opus_queue_count;
        g_uart_opus_decode_push_busy = 1;
        opusLen = UartLinkOpusQueuePop(g_uart_opus_work_frame,
                                       (uint16_t)sizeof(g_uart_opus_work_frame));
        if (opusLen > 0U) {
            uint16_t samples = 0;
            uint32_t decodeSeq = g_uart_opus_pop_count;
            OhosOpusPacketInfo preInfo;
            int32_t preRet;
            uint32_t stateBefore;
            UartLinkOpusFrameTrace *trace;

            preRet = OhosOpusValidatePacket(g_uart_opus_work_frame, opusLen, &preInfo);
            stateBefore = g_p4_audio_state;
            trace = UartLinkOpusTraceBegin(opusLen, stateBefore, qBefore, &preInfo, preRet);
            if (preRet != 0 || !preInfo.valid) {
                g_uart_opus_drop_count++;
                g_uart_opus_precheck_fail++;
                trace->dec_ret = preRet;
                if (g_uart_opus_precheck_fail <= 10U ||
                    (g_uart_opus_precheck_fail % 20U) == 0U) {
                    esp_rom_printf("[WS63-UART-OPUS] drop popped invalid len=%u frames=%ld samples=%ld err=%ld q=%u drop=%u preFail=%u\n",
                                   opusLen,
                                   (long)preInfo.frames,
                                   (long)preInfo.samples,
                                   (long)preInfo.error,
                                   g_uart_opus_queue_count,
                                   g_uart_opus_drop_count,
                                   g_uart_opus_precheck_fail);
                    UartLinkOpusDumpRecentHistory("popped_invalid");
                }
                g_uart_opus_decode_push_busy = 0;
                P4AudioStateFinishDownlinkIfIdle();
                if (OHOS_UART_OPUS_PLAY_YIELD_TICKS > 0U) {
                    LOS_TaskDelay(OHOS_UART_OPUS_PLAY_YIELD_TICKS);
                }
                continue;
            }

            if (!P4AudioStateTryStartDownlink("opus_frame_pop")) {
                g_uart_opus_drop_count++;
                g_p4_audio_downlink_guard_drop++;
                trace->dec_ret = -0x71;
                if (g_p4_audio_downlink_guard_drop <= 5U ||
                    (g_p4_audio_downlink_guard_drop % 20U) == 0U) {
                    esp_rom_printf("[WS63-UART-OPUS] drop popped frame by state len=%u state=%s guardDrop=%u totalDrop=%u\n",
                                   opusLen,
                                   P4AudioStateName(g_p4_audio_state),
                                   g_p4_audio_downlink_guard_drop,
                                   g_uart_opus_drop_count);
                }
                g_uart_opus_decode_push_busy = 0;
                P4AudioStateFinishDownlinkIfIdle();
                if (OHOS_UART_OPUS_PLAY_YIELD_TICKS > 0U) {
                    LOS_TaskDelay(OHOS_UART_OPUS_PLAY_YIELD_TICKS);
                }
                continue;
            }

            if (decodeSeq <= 3U || (decodeSeq % 100U) == 0U) {
                esp_rom_printf("[WS63-UART-OPUS] decode begin seq=%u len=%u q=%u drop=%u state=%s preFrames=%ld preSamples=%ld\n",
                               decodeSeq,
                               opusLen,
                               g_uart_opus_queue_count,
                               g_uart_opus_drop_count,
                               P4AudioStateName(g_p4_audio_state),
                               (long)preInfo.frames,
                               (long)preInfo.samples);
            }

            UartLinkOpusCodecLock();
            int32_t decRet = OhosOpusDecode(g_uart_opus_work_frame,
                                            opusLen,
                                            g_uart_opus_pcm,
                                            OHOS_OPUS_MAX_PCM_SAMPLES,
                                            &samples);
            UartLinkOpusCodecUnlock();
            trace->dec_ret = decRet;
            trace->dec_samples = samples;
            if (decRet != 0 || samples == 0U) {
                g_uart_opus_decode_fail++;
                esp_rom_printf("[WS63-UART-OPUS] decode fail len=%u ret=%ld q=%u ok=%u fail=%u\n",
                               opusLen,
                               (long)decRet,
                               g_uart_opus_queue_count,
                               g_uart_opus_decode_ok,
                               g_uart_opus_decode_fail);
                UartLinkOpusDumpRecentHistory("decode_fail");
                g_uart_opus_decode_push_busy = 0;
                P4AudioStateFinishDownlinkIfIdle();
                if (OHOS_UART_OPUS_PLAY_YIELD_TICKS > 0U) {
                    LOS_TaskDelay(OHOS_UART_OPUS_PLAY_YIELD_TICKS);
                }
                continue;
            }

            g_uart_opus_decode_ok++;
            g_uart_opus_last_samples = samples;

            uint32_t isLoopbackFrame = (preInfo.samples == (int32_t)OHOS_OPUS_UPLINK_PCM_SAMPLES ||
                                        samples == OHOS_OPUS_UPLINK_PCM_SAMPLES ||
                                        opusLen == OHOS_OPUS_UPLINK_TARGET_BYTES);
            if (g_uart_down_audio_stream_open) {
                isLoopbackFrame = 0U;
            }
            if (isLoopbackFrame) {
                UartLinkPcmApplyGainInPlace(g_uart_opus_pcm, samples, OHOS_UART_LOOPBACK_GAIN);
                uint32_t loopPeak = UartLinkPcmPeakAbs(g_uart_opus_pcm, samples);
                if (loopPeak > g_uart_downlink_loopback_peak) {
                    g_uart_downlink_loopback_peak = loopPeak;
                }
                g_uart_downlink_loopback_samples += samples;
            }
            uint32_t playRet = UartLinkPcmRingWriteBlocking(g_uart_opus_pcm,
                                                            samples,
                                                            isLoopbackFrame ? "loopback_640" : "downlink");
            trace->play_ret = playRet;
            if (playRet == 0U) {
                g_uart_opus_play_ok++;
                g_uart_downlink_decoded_samples += samples;
                uint32_t pcmLevelAfterPush = UartLinkPcmRingLevelSamples();
                if (g_uart_down_audio_first_pcm_push_ms == 0U) {
                    g_uart_down_audio_first_pcm_push_ms = (uint32_t)esp_log_timestamp();
                    esp_rom_printf("[P4-DOWNLINK-TIMING] first PCM push seq=%u startDelay=%u frameDelay=%u level=%u samples=%u\n",
                                   g_uart_downlink_session_seq,
                                   g_uart_down_audio_last_start_ms ?
                                   (uint32_t)(g_uart_down_audio_first_pcm_push_ms -
                                              g_uart_down_audio_last_start_ms) : 0U,
                                   g_uart_down_audio_first_frame_ms ?
                                   (uint32_t)(g_uart_down_audio_first_pcm_push_ms -
                                              g_uart_down_audio_first_frame_ms) : 0U,
                                   pcmLevelAfterPush,
                                   samples);
                }
                if (pcmLevelAfterPush > g_uart_downlink_pcm_max_level) {
                    g_uart_downlink_pcm_max_level = pcmLevelAfterPush;
                }
            } else {
                g_uart_opus_play_fail++;
            }

            uint32_t dropChanged = (g_uart_opus_drop_count != g_uart_opus_last_logged_drop);
            if (playRet != 0U ||
                g_uart_opus_pop_count <= 3U ||
                (g_uart_opus_pop_count % (isLoopbackFrame ? 20U : 100U)) == 0U ||
                dropChanged) {
                esp_rom_printf("[WS63-UART-OPUS] frame done len=%u preSamples=%ld samples=%u pcmPush=%u pcmLevel=%u q=%u pop=%u decOk=%u decFail=%u pushOk=%u pushFail=%u drop=%u\n",
                               opusLen,
                               (long)preInfo.samples,
                               samples,
                               playRet,
                               UartLinkPcmRingLevelSamples(),
                               g_uart_opus_queue_count,
                               g_uart_opus_pop_count,
                               g_uart_opus_decode_ok,
                               g_uart_opus_decode_fail,
                               g_uart_opus_play_ok,
                               g_uart_opus_play_fail,
                               g_uart_opus_drop_count);
                g_uart_opus_last_logged_drop = g_uart_opus_drop_count;
            }
            if (playRet != 0U) {
                UartLinkOpusDumpRecentHistory("play_fail");
            }
            g_uart_opus_decode_push_busy = 0;
            P4AudioStateFinishDownlinkIfIdle();
            if (playRet == 0U &&
                g_p4_audio_state == P4_AUDIO_STATE_DOWNLINK_PLAYING &&
                g_uart_opus_queue_count > 0U &&
                UartLinkPcmRingLevelSamples() < OHOS_UART_PCM_DECODE_AHEAD_HIGH_WATER &&
                UartLinkPcmRingFreeSamples() >= OHOS_OPUS_MAX_PCM_SAMPLES) {
                continue;
            }
            if (OHOS_UART_OPUS_PLAY_YIELD_TICKS > 0U) {
                LOS_TaskDelay(OHOS_UART_OPUS_PLAY_YIELD_TICKS);
            }
        } else {
            g_uart_opus_decode_push_busy = 0;
        }

        P4AudioStateFinishDownlinkIfIdle();
    }

    return NULL;
}

static void UartLinkOpusPlayStartTask(void)
{
    UINT32 semRet;
    UINT32 taskRet;

    UartLinkOpusQueueInit();
    UartLinkPcmPlaybackStartTask();

    if (!g_uart_opus_sem_ready) {
        semRet = LOS_SemCreate(0, &g_uart_opus_sem);
        g_uart_opus_sem_ready = (semRet == LOS_OK);
        esp_rom_printf("[WS63-UART-OPUS] sem create ret=%u sem=%u ready=%u\n",
                       semRet,
                       g_uart_opus_sem,
                       g_uart_opus_sem_ready);
    }

    if (g_uart_opus_play_task_id != 0U) {
        return;
    }

    taskRet = UartLinkCreateExternalStackTask("ohos_opus_play",
                                              (TSK_ENTRY_FUNC)UartLinkOpusPlayTask,
                                              0,
                                              OHOS_UART_OPUS_PLAY_TASK_PRIO,
                                              OHOS_UART_OPUS_PLAY_TASK_STACK,
                                              &g_uart_opus_play_task_id);
    esp_rom_printf("[WS63-UART-OPUS] play task create ret=%u taskId=%u prio=%u stack=0x%x\n",
                   taskRet,
                   g_uart_opus_play_task_id,
                   OHOS_UART_OPUS_PLAY_TASK_PRIO,
                   OHOS_UART_OPUS_PLAY_TASK_STACK);

    if (taskRet != LOS_OK) {
        g_uart_opus_play_task_id = 0;
    }
}

static VOID *UartLinkUplinkOpusTask(UINT32 arg)
{
    (void)arg;

    g_uart_up_opus_task_started = 1;
    ESP_LOGI("WS63-UART-UP-OPUS",
             "task start prio=%u stack=0x%x frameMs=%u pcmSamples=%u bitrate=%u targetBytes=%u",
             OHOS_UART_UP_OPUS_TASK_PRIO,
             OHOS_UART_UP_OPUS_TASK_STACK,
             OHOS_OPUS_UPLINK_FRAME_MS,
             OHOS_OPUS_UPLINK_PCM_SAMPLES,
             OHOS_OPUS_UPLINK_BITRATE,
             OHOS_OPUS_UPLINK_TARGET_BYTES);

    uint32_t prepareFailStreak = 0;

    while (1) {
        uint16_t opusLen = 0;
        int32_t encRet;
        uint32_t readRet;
        uint32_t txOk;
        uint32_t frameStartMs;
        OhosAudioEs7210UplinkCaptureSnapshot capSnap;

        if (g_uart_up_opus_stop_req || (!g_uart_up_opus_running && g_uart_up_opus_vad_session_active)) {
            uint32_t downlinkPreemptStop = g_uart_downlink_preempt_stop_pending;
            if (!downlinkPreemptStop) {
                P4AudioStateSet(P4_AUDIO_STATE_UPLINK_STOPPING, "uplink_stop");
            } else if (g_uart_downlink_preempt_count <= 10U ||
                       (g_uart_downlink_preempt_count % 20U) == 0U) {
                esp_rom_printf("[P4-AUDIO-SM] uplink stop ack under downlink preempt state=%s vadActive=%u stopReq=%u\n",
                               P4AudioStateName(g_p4_audio_state),
                               g_uart_up_opus_vad_session_active,
                               g_uart_up_opus_stop_req);
            }
            uint32_t hadVadSession = g_uart_up_opus_vad_session_active;
            if (g_uart_up_opus_vad_session_active) {
                uint32_t vadEndOk = UartLinkSendUplinkControlFrame(OHOS_UART_CMD_SET_FORCE_VAD_END,
                                                                    "SET_FORCE_VAD_END");
                if (vadEndOk) {
                    g_uart_up_opus_vad_end_ok++;
                    g_uart_up_opus_vad_session_active = 0;
                    g_uart_up_opus_last_vad_end_ms = (uint32_t)esp_log_timestamp();
                } else {
                    g_uart_up_opus_vad_end_fail++;
                }
            }
            g_uart_up_opus_running = 0;
            g_uart_up_opus_stop_req = 0;
            OhosAudioEs7210StopUplinkCapture();
            g_uart_up_opus_capture_started = 0;
            if (downlinkPreemptStop) {
                if (!hadVadSession || !g_uart_up_opus_vad_session_active) {
                    g_uart_downlink_preempt_stop_pending = 0;
                    ESP_LOGI("WS63-UART-UP-OPUS",
                             "preempt stop acknowledged keepState=%s hadVad=%u vadActive=%u vadE=%u/%u keepRxStopped=1",
                             P4AudioStateName(g_p4_audio_state),
                             hadVadSession,
                             g_uart_up_opus_vad_session_active,
                             g_uart_up_opus_vad_end_ok,
                             g_uart_up_opus_vad_end_fail);
                } else {
                    ESP_LOGW("WS63-UART-UP-OPUS",
                             "preempt stop VAD_END pending keepState=%s vadE=%u/%u",
                             P4AudioStateName(g_p4_audio_state),
                             g_uart_up_opus_vad_end_ok,
                             g_uart_up_opus_vad_end_fail);
                    LOS_TaskDelay(5);
                }
                continue;
            }
            if (hadVadSession && !g_uart_up_opus_vad_session_active) {
                P4AudioStateSet(P4_AUDIO_STATE_WAIT_ASR, "uplink_vad_end");
            } else if (hadVadSession) {
                P4AudioStateSet(P4_AUDIO_STATE_ERROR_RECOVER, "uplink_vad_end_fail");
                P4AudioStateSet(P4_AUDIO_STATE_IDLE, "recover_after_vad_end_fail");
            } else {
                P4AudioStateSet(P4_AUDIO_STATE_IDLE, "uplink_stop_before_vad");
            }
            OhosAudioEs7210GetUplinkCaptureSnapshot(&capSnap);
            uint32_t sessionMs = (g_uart_up_opus_session_start_ms == 0U) ?
                                 0U : (uint32_t)(esp_log_timestamp() -
                                                 g_uart_up_opus_session_start_ms);
            uint32_t txDelta = g_uart_up_opus_tx_ok - g_uart_up_opus_session_tx_base;
            uint32_t expected = (sessionMs + (OHOS_OPUS_UPLINK_FRAME_MS / 2U)) /
                                OHOS_OPUS_UPLINK_FRAME_MS;
            uint32_t ratio = expected ? ((txDelta * 100U) / expected) : 0U;
            ESP_LOGI("WS63-UART-UP-OPUS",
                     "stop acknowledged stopCnt=%u txOk=%u txFail=%u encFail=%u pcmFail=%u vadS=%u/%u vadE=%u/%u",
                     g_uart_up_opus_stop_count,
                     g_uart_up_opus_tx_ok,
                     g_uart_up_opus_tx_fail,
                     g_uart_up_opus_encode_fail,
                     g_uart_up_opus_pcm_fail,
                     g_uart_up_opus_vad_start_ok,
                     g_uart_up_opus_vad_start_fail,
                     g_uart_up_opus_vad_end_ok,
                     g_uart_up_opus_vad_end_fail);
            ESP_LOGI("WS63-UART-UP-OPUS",
                     "P4-UP-SUMMARY dur=%u txDelta=%u expected=%u ratio=%u%% producedSamples=%u consumedSamples=%u ring=%u min=%u max=%u underflow=%u overflow=%u readOk=%u readFail=%u peak=%u nonzero=%u use=%s quality=%s",
                     sessionMs,
                     txDelta,
                     expected,
                     ratio,
                     capSnap.produced_samples,
                     capSnap.consumed_samples,
                     capSnap.ring_level,
                     capSnap.min_level,
                     capSnap.max_level,
                     capSnap.underflow,
                     capSnap.overflow,
                     capSnap.read_ok,
                     capSnap.read_fail,
                     capSnap.peak,
                     capSnap.nonzero,
                     capSnap.use_right ? "R" : "L",
                     (ratio >= OHOS_UART_UP_OPUS_SUMMARY_MIN_RATIO) ? "OK" : "LOW");
            continue;
        }

        if (!g_uart_up_opus_running) {
            LOS_TaskDelay(5);
            continue;
        }

        if (!g_uart_driver_init_ok || !g_uart_link_ready) {
            P4AudioStateSet(P4_AUDIO_STATE_UPLINK_PREPARE, "uplink_wait_link");
            g_uart_up_opus_last_ret = 0xfffffffdU;
            if ((g_uart_up_opus_pcm_fail % 25U) == 0U) {
                ESP_LOGI("WS63-UART-UP-OPUS",
                         "wait link driver=%u linkReady=%u running=%u",
                         g_uart_driver_init_ok,
                         g_uart_link_ready,
                         g_uart_up_opus_running);
            }
            g_uart_up_opus_pcm_fail++;
            LOS_TaskDelay(10);
            continue;
        }

        if (!g_uart_up_opus_vad_session_active) {
            P4AudioStateSet(P4_AUDIO_STATE_UPLINK_PREPARE, "prepare_first_opus");
        }

        if (!g_uart_up_opus_capture_started) {
            uint32_t capRet = OhosAudioEs7210StartUplinkCapture();
            if (capRet != 0U) {
                g_uart_up_opus_pcm_fail++;
                g_uart_up_opus_last_ret = capRet;
                prepareFailStreak++;
                if (prepareFailStreak >= OHOS_UART_UP_OPUS_PREPARE_MAX_FAILS) {
                    g_uart_up_opus_running = 0;
                    g_uart_up_opus_stop_req = 0;
                    P4AudioStateSet(P4_AUDIO_STATE_IDLE, "prepare_capture_fail_limit");
                    ESP_LOGW("WS63-UART-UP-OPUS",
                             "prepare aborted by capture start fail streak=%u ret=%u pcmFail=%u",
                             prepareFailStreak,
                             capRet,
                             g_uart_up_opus_pcm_fail);
                    prepareFailStreak = 0;
                }
                LOS_TaskDelay(5);
                continue;
            }
            g_uart_up_opus_capture_started = 1;
            (void)UartLinkUplinkWaitCaptureStartLevel(OHOS_UART_UP_OPUS_CAPTURE_START_LEVEL,
                                                      OHOS_UART_UP_OPUS_CAPTURE_START_MAX_MS);
        }

        frameStartMs = (uint32_t)esp_log_timestamp();

        readRet = OhosAudioEs7210ReadUplinkCaptureFrame(g_uart_up_opus_pcm,
                                                        OHOS_OPUS_UPLINK_PCM_SAMPLES,
                                                        OHOS_UART_UP_OPUS_CAPTURE_FRAME_WAIT_MS);
        OhosAudioEs7210GetUplinkCaptureSnapshot(&capSnap);
        g_uart_up_opus_last_peak = capSnap.peak;
        g_uart_up_opus_last_nonzero = capSnap.nonzero;
        g_uart_up_opus_last_samples = OHOS_OPUS_UPLINK_PCM_SAMPLES;

        if (readRet != 0U) {
            g_uart_up_opus_pcm_fail++;
            g_uart_up_opus_session_underflow++;
            g_uart_up_opus_last_ret = readRet;
            if (!g_uart_up_opus_vad_session_active) {
                prepareFailStreak++;
                if (prepareFailStreak >= OHOS_UART_UP_OPUS_PREPARE_MAX_FAILS) {
                    g_uart_up_opus_running = 0;
                    g_uart_up_opus_stop_req = 0;
                    OhosAudioEs7210StopUplinkCapture();
                    g_uart_up_opus_capture_started = 0;
                    P4AudioStateSet(P4_AUDIO_STATE_IDLE, "prepare_pcm_fail_limit");
                    ESP_LOGW("WS63-UART-UP-OPUS",
                             "prepare aborted by pcm fail streak=%u pcmFail=%u",
                             prepareFailStreak,
                             g_uart_up_opus_pcm_fail);
                    prepareFailStreak = 0;
                }
            }
            LOS_TaskDelay(1);
            continue;
        }
        if (!g_uart_up_opus_running || g_uart_up_opus_stop_req) {
            continue;
        }
        g_uart_up_opus_pcm_ok++;

        UartLinkOpusCodecLock();
        encRet = OhosOpusEncodePcm16Mono(g_uart_up_opus_pcm,
                                         OHOS_OPUS_UPLINK_PCM_SAMPLES,
                                         g_uart_up_opus_payload,
                                         (uint16_t)sizeof(g_uart_up_opus_payload),
                                         &opusLen);
        UartLinkOpusCodecUnlock();
        if (encRet != 0 || opusLen == 0U) {
            g_uart_up_opus_encode_fail++;
            g_uart_up_opus_last_ret = (uint32_t)encRet;
            if (!g_uart_up_opus_vad_session_active) {
                prepareFailStreak++;
                if (prepareFailStreak >= OHOS_UART_UP_OPUS_PREPARE_MAX_FAILS) {
                    g_uart_up_opus_running = 0;
                    g_uart_up_opus_stop_req = 0;
                    OhosAudioEs7210StopUplinkCapture();
                    g_uart_up_opus_capture_started = 0;
                    P4AudioStateSet(P4_AUDIO_STATE_IDLE, "prepare_encode_fail_limit");
                    ESP_LOGW("WS63-UART-UP-OPUS",
                             "prepare aborted by encode fail streak=%u encFail=%u",
                             prepareFailStreak,
                             g_uart_up_opus_encode_fail);
                    prepareFailStreak = 0;
                }
            }
            LOS_TaskDelay(1);
            continue;
        }
        if (!g_uart_up_opus_running || g_uart_up_opus_stop_req) {
            continue;
        }
        g_uart_up_opus_encode_ok++;
        g_uart_up_opus_last_len = opusLen;
        prepareFailStreak = 0;

        if (!g_uart_up_opus_vad_session_active) {
            uint32_t vadStartOk = UartLinkSendUplinkControlFrame(OHOS_UART_CMD_SET_VAD_START,
                                                                 "SET_VAD_START");
            if (vadStartOk) {
                g_uart_up_opus_vad_start_ok++;
                g_uart_up_opus_vad_session_active = 1;
                P4AudioStateSet(P4_AUDIO_STATE_UPLINK_RECORDING, "first_opus_ready");
            } else {
                g_uart_up_opus_vad_start_fail++;
                g_uart_up_opus_last_ret = 0xfffffff0U;
                LOS_TaskDelay(10);
                continue;
            }
        }

        txOk = UartLinkSendUplinkOpusFrame(g_uart_up_opus_payload, opusLen);
        if (txOk) {
            g_uart_up_opus_tx_ok++;
        } else {
            g_uart_up_opus_tx_fail++;
        }

        if (!txOk ||
            g_uart_up_opus_tx_ok <= OHOS_UART_UP_OPUS_FRAME_LOG_FIRST ||
            (g_uart_up_opus_tx_ok % OHOS_UART_UP_OPUS_FRAME_LOG_EVERY) == 0U ||
            opusLen != OHOS_OPUS_UPLINK_TARGET_BYTES) {
            ESP_LOGI("WS63-UART-UP-OPUS",
                     "frame done pcmOk=%u pcmFail=%u encOk=%u encFail=%u txOk=%u txFail=%u opusLen=%u peak=%u nonzero=%u linkReady=%u elapsed=%u",
                     g_uart_up_opus_pcm_ok,
                     g_uart_up_opus_pcm_fail,
                     g_uart_up_opus_encode_ok,
                     g_uart_up_opus_encode_fail,
                     g_uart_up_opus_tx_ok,
                     g_uart_up_opus_tx_fail,
                     opusLen,
                     g_uart_up_opus_last_peak,
                     g_uart_up_opus_last_nonzero,
                     g_uart_link_ready,
                     (uint32_t)(esp_log_timestamp() - frameStartMs));
        }

        /*
         * The ES7210 producer is now the clock source: it contributes 320 mono
         * samples every 20ms, so waiting for 640 samples naturally paces uplink
         * Opus at 40ms without relying on LiteOS ms-delay conversion.
         */
        if (OHOS_UART_UP_OPUS_UI_YIELD_EVERY > 0U &&
            (g_uart_up_opus_tx_ok % OHOS_UART_UP_OPUS_UI_YIELD_EVERY) == 0U) {
            LOS_TaskDelay(1);
        }
        LOS_TaskYield();
    }

    return NULL;
}

static void UartLinkUplinkOpusStartTask(void)
{
    if (g_uart_up_opus_task_started || g_uart_up_opus_task_id != 0U) {
        return;
    }

    uint32_t ret = UartLinkCreateExternalStackTask("ohos_up_opus",
                                                   (TSK_ENTRY_FUNC)UartLinkUplinkOpusTask,
                                                   0,
                                                   OHOS_UART_UP_OPUS_TASK_PRIO,
                                                   OHOS_UART_UP_OPUS_TASK_STACK,
                                                   &g_uart_up_opus_task_id);
    esp_rom_printf("[WS63-UART-UP-OPUS] task create ret=%u taskId=%u prio=%u stack=0x%x\n",
                   ret,
                   g_uart_up_opus_task_id,
                   OHOS_UART_UP_OPUS_TASK_PRIO,
                   OHOS_UART_UP_OPUS_TASK_STACK);

    if (ret != LOS_OK) {
        g_uart_up_opus_task_id = 0;
    }
}

static void UartLinkHandleDownAudioFrame(const OhosUartProtoFrame *frame)
{
    if (frame == NULL) {
        return;
    }

    g_uart_down_audio_count++;
    g_uart_down_audio_bytes += frame->payload_len;
    g_uart_down_audio_last_len = frame->payload_len;

    if (g_uart_down_audio_count <= 3U || (g_uart_down_audio_count % 100U) == 0U) {
        esp_rom_printf("[WS63-UART-DOWN-AUDIO] count=%u cmd=0x%04x payloadLen=%u totalBytes=%u\n",
                       g_uart_down_audio_count,
                       frame->cmd_type,
                       frame->payload_len,
                       g_uart_down_audio_bytes);
    }

    if (g_uart_down_audio_count == 1U) {
        UartLinkDumpHex("[WS63-UART-DOWN-AUDIO-RAW]", frame->payload, frame->payload_len);
    }

    UartLinkHandleDownAudioPayload(frame->payload, frame->payload_len);
}

static void UartLinkHandleAgentStatusFrame(const OhosUartProtoFrame *frame)
{
    if (frame == NULL || frame->payload == NULL || frame->payload_len != 1U) {
        g_uart_agent_status_invalid_count++;
        esp_rom_printf("[WS63-UART-AGENT] invalid payloadLen=%u invalid=%u\n",
                       frame ? frame->payload_len : 0U,
                       g_uart_agent_status_invalid_count);
        return;
    }

    uint32_t status = frame->payload[0];
    if (status > 3U) {
        g_uart_agent_status_invalid_count++;
        esp_rom_printf("[WS63-UART-AGENT] invalid state=%u invalid=%u\n",
                       status,
                       g_uart_agent_status_invalid_count);
        return;
    }

    g_uart_agent_status = status;
    g_uart_agent_status_rx_count++;
    esp_rom_printf("[WS63-UART-AGENT] rx SET_AGENT_STATUS state=%u %s count=%u audioState=%s\n",
                   status,
                   UartLinkAgentStatusName(status),
                   g_uart_agent_status_rx_count,
                   P4AudioStateName(g_p4_audio_state));
}

static void UartLinkHandleWakeStatusFrame(const OhosUartProtoFrame *frame)
{
