static const char *P4AudioStateName(uint32_t state)
{
    switch (state) {
        case P4_AUDIO_STATE_IDLE:
            return "IDLE";
        case P4_AUDIO_STATE_UPLINK_PREPARE:
            return "UPLINK_PREPARE";
        case P4_AUDIO_STATE_UPLINK_RECORDING:
            return "UPLINK_RECORDING";
        case P4_AUDIO_STATE_UPLINK_STOPPING:
            return "UPLINK_STOPPING";
        case P4_AUDIO_STATE_WAIT_ASR:
            return "WAIT_ASR";
        case P4_AUDIO_STATE_DOWNLINK_PLAYING:
            return "DOWNLINK_PLAYING";
        case P4_AUDIO_STATE_ERROR_RECOVER:
            return "ERROR_RECOVER";
        default:
            return "UNKNOWN";
    }
}

static const char *UartLinkAgentStatusName(uint32_t status)
{
    switch (status) {
        case 0U:
            return "Idle";
        case 1U:
            return "Wakeup";
        case 2U:
            return "Listening";
        case 3U:
            return "Speaking";
        default:
            return "Unknown";
    }
}

static uint32_t P4AudioStateIsUplinkBusy(uint32_t state)
{
    return (state == P4_AUDIO_STATE_UPLINK_PREPARE ||
            state == P4_AUDIO_STATE_UPLINK_RECORDING ||
            state == P4_AUDIO_STATE_UPLINK_STOPPING);
}

static void P4AudioStateSet(uint32_t next, const char *reason)
{
    uint32_t intSave = LOS_IntLock();
    uint32_t prev = g_p4_audio_state;
    if (prev != next) {
        g_p4_audio_state = next;
        g_p4_audio_state_transition_count++;
    }
    LOS_IntRestore(intSave);

    if (prev != next) {
        esp_rom_printf("[P4-AUDIO-SM] %s -> %s reason=%s trans=%u\n",
                       P4AudioStateName(prev),
                       P4AudioStateName(next),
                       reason ? reason : "-",
                       g_p4_audio_state_transition_count);
    }
}

static uint32_t P4AudioStateTryStartUplink(const char *reason)
{
    uint32_t ok = 0;
    uint32_t intSave = LOS_IntLock();
    uint32_t state = g_p4_audio_state;
    uint32_t qCount = g_uart_opus_queue_count;
    if ((state == P4_AUDIO_STATE_IDLE || state == P4_AUDIO_STATE_WAIT_ASR) &&
        qCount == 0U &&
        UartLinkPcmRingLevelSamples() == 0U &&
        !g_uart_pcm_play_write_busy &&
        !g_uart_opus_decode_push_busy) {
        g_p4_audio_state = P4_AUDIO_STATE_UPLINK_PREPARE;
        g_p4_audio_state_transition_count++;
        ok = 1;
    }
    LOS_IntRestore(intSave);

    if (ok) {
        esp_rom_printf("[P4-AUDIO-SM] %s -> %s reason=%s trans=%u\n",
                       P4AudioStateName(state),
                       P4AudioStateName(P4_AUDIO_STATE_UPLINK_PREPARE),
                       reason ? reason : "-",
                       g_p4_audio_state_transition_count);
    } else {
        esp_rom_printf("[P4-AUDIO-SM] reject uplink start state=%s q=%u pcm=%u i2sBusy=%u decodeBusy=%u reason=%s\n",
                       P4AudioStateName(state),
                       qCount,
                       UartLinkPcmRingLevelSamples(),
                       g_uart_pcm_play_write_busy,
                       g_uart_opus_decode_push_busy,
                       reason ? reason : "-");
    }
    return ok;
}

static uint32_t P4AudioStateTryStartDownlink(const char *reason)
{
    uint32_t ok = 0;
    uint32_t changed = 0;
    uint32_t intSave = LOS_IntLock();
    uint32_t state = g_p4_audio_state;
    if (state == P4_AUDIO_STATE_DOWNLINK_PLAYING) {
        ok = 1;
    } else if (state == P4_AUDIO_STATE_IDLE || state == P4_AUDIO_STATE_WAIT_ASR) {
        g_p4_audio_state = P4_AUDIO_STATE_DOWNLINK_PLAYING;
        g_p4_audio_state_transition_count++;
        ok = 1;
        changed = 1;
    }
    LOS_IntRestore(intSave);

    if (changed) {
        esp_rom_printf("[P4-AUDIO-SM] %s -> %s reason=%s trans=%u\n",
                       P4AudioStateName(state),
                       P4AudioStateName(P4_AUDIO_STATE_DOWNLINK_PLAYING),
                       reason ? reason : "-",
                       g_p4_audio_state_transition_count);
    }
    return ok;
}

static uint32_t P4AudioPrepareDownlinkSessionIfNeeded(const char *reason)
{
    uint32_t seq = g_uart_downlink_session_seq;
    uint32_t prepared = g_uart_downlink_session_prepared_seq;
    uint32_t waitMs = 0;
    uint32_t nowMs;

    if (seq == 0U || prepared == seq) {
        return 1;
    }

    while ((g_uart_up_opus_running ||
            g_uart_up_opus_stop_req ||
            g_uart_up_opus_vad_session_active ||
            g_p4_audio_state == P4_AUDIO_STATE_UPLINK_STOPPING) &&
           waitMs < OHOS_UART_DOWNLINK_PREPARE_MAX_WAIT_MS) {
        OhosAudioEs7210RequestPcmStopForDownlink();
        OhosLiteosDelayMs(5);
        waitMs += 5U;
    }

    if (g_uart_up_opus_running ||
        g_uart_up_opus_stop_req ||
        g_uart_up_opus_vad_session_active ||
        g_p4_audio_state == P4_AUDIO_STATE_UPLINK_STOPPING) {
        g_uart_downlink_prepare_fail++;
        if (g_uart_downlink_prepare_fail <= 5U ||
            (g_uart_downlink_prepare_fail % 20U) == 0U) {
            esp_rom_printf("[P4-AUDIO-SM] downlink prepare wait busy seq=%u prepared=%u state=%s run=%u stopReq=%u vad=%u wait=%u fail=%u reason=%s\n",
                           seq,
                           prepared,
                           P4AudioStateName(g_p4_audio_state),
                           g_uart_up_opus_running,
                           g_uart_up_opus_stop_req,
                           g_uart_up_opus_vad_session_active,
                           waitMs,
                           g_uart_downlink_prepare_fail,
                           reason ? reason : "-");
        }
        return 0;
    }

    nowMs = (uint32_t)esp_log_timestamp();
    g_uart_downlink_prepare_count++;
    if (g_p4_audio_state == P4_AUDIO_STATE_WAIT_ASR) {
        g_uart_downlink_start_after_vad_end++;
    }

    esp_rom_printf("[P4-AUDIO-SM] prepare downlink session seq=%u prepared=%u q=%u state=%s wait=%u reason=%s startAgo=%u vadEndAgo=%u\n",
                   seq,
                   prepared,
                   g_uart_opus_queue_count,
                   P4AudioStateName(g_p4_audio_state),
                   waitMs,
                   reason ? reason : "-",
                   g_uart_down_audio_last_start_ms ?
                   (uint32_t)(nowMs - g_uart_down_audio_last_start_ms) : 0U,
                   (uint32_t)(nowMs - g_uart_up_opus_last_vad_end_ms));

    OhosAudioEs7210RequestPcmStopForDownlink();
    (void)OhosAudioEs7210PrepareForDownlink(OHOS_UART_DOWNLINK_RX_SETTLE_MS);

    if (OhosAudioEs8311PortPrepareForDialog(OHOS_UART_DOWNLINK_TX_SETTLE_MS) != 0U) {
        g_uart_downlink_es8311_prepare_fail++;
        esp_rom_printf("[P4-AUDIO-SM] prepare downlink tx fail seq=%u fail=%u reason=%s\n",
                       seq,
                       g_uart_downlink_es8311_prepare_fail,
                       reason ? reason : "-");
        return 0;
    }

    UartLinkPcmRingReset("prepare_downlink_session");
    g_uart_pcm_play_started_session = 0;
    g_uart_pcm_play_prefill_start_ms = 0;
    g_uart_pcm_play_block_wait_start_ms = 0;
    g_uart_downlink_session_start_ms = (uint32_t)esp_log_timestamp();
    g_uart_downlink_first_play_ms = 0;
    g_uart_downlink_decoded_samples = 0;
    g_uart_downlink_played_samples = 0;
    g_uart_downlink_write_count = 0;
    g_uart_downlink_pcm_min_level = 0xffffffffU;
    g_uart_downlink_pcm_max_level = 0;
    g_uart_downlink_pcm_wait_ms = 0;
    g_uart_downlink_prefill_wait_ms = 0;
    g_uart_downlink_loopback_samples = 0;
    g_uart_downlink_loopback_peak = 0;
    g_uart_downlink_loopback_pad_done = 0;
    g_uart_downlink_loopback_pad_remaining = 0;
    g_uart_down_audio_first_frame_ms = 0;
    g_uart_down_audio_first_pcm_push_ms = 0;
    g_uart_down_audio_first_play_ms = 0;
    g_uart_down_audio_stream_underrun = 0;
    g_uart_down_audio_stream_min_level = 0xffffffffU;

    UartLinkOpusCodecLock();
    (void)OhosOpusDecoderReset();
    UartLinkOpusCodecUnlock();

    g_uart_downlink_session_prepared_seq = seq;
    if (reason != NULL && strcmp(reason, "down_audio_start") == 0) {
        g_uart_down_audio_prepared_on_start++;
    }
    g_uart_down_audio_prepare_pending = 0U;
    esp_rom_printf("[P4-AUDIO-SM] prepare downlink done seq=%u reason=%s startDelay=%u preparedOnStart=%u\n",
                   seq,
                   reason ? reason : "-",
                   g_uart_down_audio_last_start_ms ?
                   (uint32_t)((uint32_t)esp_log_timestamp() - g_uart_down_audio_last_start_ms) : 0U,
                   g_uart_down_audio_prepared_on_start);
    return 1;
}

static void P4AudioStateFinishDownlinkIfIdle(void)
{
    if (g_p4_audio_state == P4_AUDIO_STATE_DOWNLINK_PLAYING &&
        g_uart_opus_queue_count == 0U &&
        UartLinkPcmRingLevelSamples() == 0U &&
        !g_uart_pcm_play_write_busy &&
        !g_uart_opus_decode_push_busy &&
        g_uart_downlink_loopback_pad_remaining == 0U) {
        uint32_t nowMs = (uint32_t)esp_log_timestamp();
        uint32_t lastRxMs = g_uart_down_audio_last_rx_ms;

        if (g_uart_down_audio_stream_open && !g_uart_down_audio_stop_seen) {
            uint32_t waitMs = lastRxMs ? (uint32_t)(nowMs - lastRxMs) : 0U;
            if (waitMs < OHOS_UART_DOWNLINK_STREAM_WAIT_MORE_MS) {
                g_uart_down_audio_wait_more_count++;
                if (g_uart_down_audio_wait_more_count <= 5U ||
                    (g_uart_down_audio_wait_more_count % 50U) == 0U) {
                    esp_rom_printf("[P4-AUDIO-SM] stream open wait more audio q=0 pcm=0 wait=%u limit=%u cnt=%u seq=%u firstDelay=%u minLevel=%u underrun=%u\n",
                                   waitMs,
                                   OHOS_UART_DOWNLINK_STREAM_WAIT_MORE_MS,
                                   g_uart_down_audio_wait_more_count,
                                   g_uart_downlink_session_seq,
                                   (g_uart_down_audio_first_play_ms && g_uart_down_audio_last_start_ms) ?
                                   (uint32_t)(g_uart_down_audio_first_play_ms - g_uart_down_audio_last_start_ms) : 0U,
                                   (g_uart_down_audio_stream_min_level == 0xffffffffU) ? 0U :
                                   g_uart_down_audio_stream_min_level,
                                   g_uart_down_audio_stream_underrun);
                }
                return;
            }
            g_uart_down_audio_wait_more_timeout++;
            esp_rom_printf("[P4-AUDIO-SM] stream wait more timeout wait=%u limit=%u timeout=%u seq=%u\n",
                           waitMs,
                           OHOS_UART_DOWNLINK_STREAM_WAIT_MORE_MS,
                           g_uart_down_audio_wait_more_timeout,
                           g_uart_downlink_session_seq);
        }

        if (!g_uart_down_audio_stream_open &&
            g_uart_downlink_loopback_samples > 0U &&
            g_uart_downlink_loopback_samples < OHOS_UART_LOOPBACK_MIN_PLAY_SAMPLES &&
            !g_uart_downlink_loopback_pad_done) {
            uint32_t padSamples = OHOS_UART_LOOPBACK_MIN_PLAY_SAMPLES -
                                  g_uart_downlink_loopback_samples;
            g_uart_downlink_loopback_pad_done = 1;
            g_uart_downlink_loopback_pad_remaining = padSamples;
            esp_rom_printf("[P4-AUDIO-SM] loopback pad silence samples=%u played=%u peak=%u min=%u\n",
                           padSamples,
                           g_uart_downlink_loopback_samples,
                           g_uart_downlink_loopback_peak,
                           OHOS_UART_LOOPBACK_MIN_PLAY_SAMPLES);
            return;
        }

        if (g_uart_down_audio_stop_seen ||
            lastRxMs == 0U ||
            (uint32_t)(nowMs - lastRxMs) >= OHOS_UART_DOWNLINK_IDLE_HOLD_MS) {
            uint32_t startMs = g_uart_downlink_session_start_ms;
            uint32_t firstMs = g_uart_downlink_first_play_ms;
            uint32_t durMs = startMs ? (uint32_t)(nowMs - startMs) : 0U;
            uint32_t firstDelayMs = (startMs && firstMs) ? (uint32_t)(firstMs - startMs) : 0U;
            uint32_t minLevel = (g_uart_downlink_pcm_min_level == 0xffffffffU) ? 0U :
                                g_uart_downlink_pcm_min_level;
            esp_rom_printf("[P4-AUDIO-SM] downlink drain complete q=%u pcm=%u i2sBusy=%u decodeBusy=%u i2sSamples=%u decSamples=%u playSamples=%u writes=%u dur=%u firstDelay=%u prefillWait=%u pcmWait=%u minLevel=%u maxLevel=%u underrun=%u overflow=%u loopSamples=%u loopPeak=%u stopSeen=%u\n",
                            g_uart_opus_queue_count,
                            UartLinkPcmRingLevelSamples(),
                            g_uart_pcm_play_write_busy,
                            g_uart_opus_decode_push_busy,
                            g_uart_pcm_i2s_samples,
                            g_uart_downlink_decoded_samples,
                            g_uart_downlink_played_samples,
                            g_uart_downlink_write_count,
                            durMs,
                            firstDelayMs,
                            g_uart_downlink_prefill_wait_ms,
                            g_uart_downlink_pcm_wait_ms,
                            minLevel,
                            g_uart_downlink_pcm_max_level,
                            g_uart_pcm_ring_underflow,
                            g_uart_pcm_ring_overflow,
                            g_uart_downlink_loopback_samples,
                            g_uart_downlink_loopback_peak,
                            g_uart_down_audio_stop_seen);
            g_uart_down_audio_stop_seen = 0U;
            g_uart_down_audio_boundary_active = 0U;
            g_uart_down_audio_explicit_start_pending = 0U;
            g_uart_down_audio_stream_open = 0U;
            g_uart_down_audio_prepare_pending = 0U;
            P4AudioStateSet(P4_AUDIO_STATE_IDLE, "downlink_idle_hold");
            if (!g_uart_downlink_preempt_stop_pending &&
                !g_uart_up_opus_running &&
                !g_uart_up_opus_stop_req &&
                !g_uart_up_opus_vad_session_active) {
                OhosAudioEs7210ClearPcmStopForDownlink();
            }
        }
    }
}

static uint32_t P4AudioRequestDownlinkPreemptUplink(const char *reason)
{
    uint32_t intSave;
    uint32_t state;
    uint32_t changed = 0;

    intSave = LOS_IntLock();
    state = g_p4_audio_state;
    if (!P4AudioStateIsUplinkBusy(state)) {
        LOS_IntRestore(intSave);
        return 0;
    }

    g_uart_downlink_preempt_count++;
    if (reason != NULL && strcmp(reason, "down_audio") == 0) {
        g_uart_downlink_preempt_audio_count++;
    } else if (reason != NULL && strcmp(reason, "down_text") == 0) {
        g_uart_downlink_preempt_text_count++;
    }

    g_uart_up_opus_stop_req = 1;
    if (g_uart_up_opus_running) {
        g_uart_up_opus_running = 0;
    }
    g_uart_downlink_preempt_stop_pending = 1;
    if (g_p4_audio_state != P4_AUDIO_STATE_WAIT_ASR) {
        g_p4_audio_state = P4_AUDIO_STATE_WAIT_ASR;
        g_p4_audio_state_transition_count++;
        changed = 1;
    }
    LOS_IntRestore(intSave);

    OhosAudioEs7210RequestPcmStopForDownlink();

    if (changed) {
        esp_rom_printf("[P4-AUDIO-SM] %s -> %s reason=%s trans=%u\n",
                       P4AudioStateName(state),
                       P4AudioStateName(P4_AUDIO_STATE_WAIT_ASR),
                       reason ? reason : "downlink_preempt",
                       g_p4_audio_state_transition_count);
    }
    if (g_uart_downlink_preempt_count <= 10U ||
        (g_uart_downlink_preempt_count % 20U) == 0U) {
        esp_rom_printf("[P4-AUDIO-SM] downlink preempt uplink state=%s reason=%s cnt=%u audio=%u text=%u vadActive=%u stopReq=%u\n",
                       P4AudioStateName(state),
                       reason ? reason : "-",
                       g_uart_downlink_preempt_count,
                       g_uart_downlink_preempt_audio_count,
                       g_uart_downlink_preempt_text_count,
                       g_uart_up_opus_vad_session_active,
                       g_uart_up_opus_stop_req);
    }

    return 1;
}

static void UartLinkOpusCodecLock(void)
{
    if (!g_uart_opus_codec_sem_ready) {
        UINT32 semRet = LOS_SemCreate(1, &g_uart_opus_codec_sem);
        g_uart_opus_codec_sem_ready = (semRet == LOS_OK);
        esp_rom_printf("[WS63-UART-OPUS] codec sem create ret=%u sem=%u ready=%u\n",
                       semRet,
                       g_uart_opus_codec_sem,
                       g_uart_opus_codec_sem_ready);
    }
    if (g_uart_opus_codec_sem_ready) {
        (void)LOS_SemPend(g_uart_opus_codec_sem, LOS_WAIT_FOREVER);
    }
}

static void UartLinkOpusCodecUnlock(void)
{
    if (g_uart_opus_codec_sem_ready) {
        (void)LOS_SemPost(g_uart_opus_codec_sem);
    }
}

static uint32_t UartLinkPcmRingLevelSamples(void)
{
    return g_uart_pcm_ring_count;
}

static uint32_t UartLinkPcmRingFreeSamples(void)
{
    uint32_t cap = g_uart_pcm_ring_capacity;
    return (cap > g_uart_pcm_ring_count) ? (uint32_t)(cap - g_uart_pcm_ring_count) : 0U;
}

static uint32_t UartLinkPcmRingInit(void)
{
    if (g_uart_pcm_ring != NULL && g_uart_pcm_ring_capacity > 0U) {
        return 1U;
    }

    size_t bytes = (size_t)OHOS_UART_PCM_RING_SAMPLES * sizeof(int16_t);
    g_uart_pcm_ring = (int16_t *)heap_caps_calloc(OHOS_UART_PCM_RING_SAMPLES,
                                                 sizeof(int16_t),
                                                 MALLOC_CAP_SPIRAM | MALLOC_CAP_8BIT);
    if (g_uart_pcm_ring != NULL) {
        g_uart_pcm_ring_capacity = OHOS_UART_PCM_RING_SAMPLES;
        esp_rom_printf("[WS63-UART-PCM] ring psram ok samples=%u bytes=%u ptr=%p\n",
                       g_uart_pcm_ring_capacity,
                       (unsigned)bytes,
                       g_uart_pcm_ring);
        return 1U;
    }

    memset(g_uart_pcm_ring_fallback, 0, sizeof(g_uart_pcm_ring_fallback));
    g_uart_pcm_ring = g_uart_pcm_ring_fallback;
    g_uart_pcm_ring_capacity = OHOS_UART_PCM_RING_FALLBACK_SAMPLES;
    esp_rom_printf("[WS63-UART-PCM] ring psram fail fallback samples=%u bytes=%u ptr=%p\n",
                   g_uart_pcm_ring_capacity,
                   (unsigned)sizeof(g_uart_pcm_ring_fallback),
                   g_uart_pcm_ring);
    return 1U;
}

static void UartLinkPcmRingReset(const char *reason)
{
    if (g_uart_pcm_ring == NULL || g_uart_pcm_ring_capacity == 0U) {
        (void)UartLinkPcmRingInit();
    }

    uint32_t intSave = LOS_IntLock();
    g_uart_pcm_read_idx = 0;
    g_uart_pcm_write_idx = 0;
    g_uart_pcm_ring_count = 0;
    LOS_IntRestore(intSave);

    esp_rom_printf("[WS63-UART-PCM] ring reset reason=%s cap=%u overflow=%u underflow=%u writeOk=%u readOk=%u i2sOk=%u i2sFail=%u\n",
                   reason ? reason : "-",
                   g_uart_pcm_ring_capacity,
                   g_uart_pcm_ring_overflow,
                   g_uart_pcm_ring_underflow,
                   g_uart_pcm_ring_write_ok,
                   g_uart_pcm_ring_read_ok,
                   g_uart_pcm_i2s_write_ok,
                   g_uart_pcm_i2s_write_fail);
}

static uint32_t UartLinkPcmRingWriteOnce(const int16_t *pcm, uint32_t samples)
{
    uint32_t intSave;
    uint32_t written = 0;

    if (g_uart_pcm_ring == NULL || g_uart_pcm_ring_capacity == 0U ||
        pcm == NULL || samples == 0U) {
        return 0;
    }

    intSave = LOS_IntLock();
    while (written < samples && g_uart_pcm_ring_count < g_uart_pcm_ring_capacity) {
        g_uart_pcm_ring[g_uart_pcm_write_idx] = pcm[written];
        g_uart_pcm_write_idx = (g_uart_pcm_write_idx + 1U) % g_uart_pcm_ring_capacity;
        g_uart_pcm_ring_count++;
        written++;
    }
    if (g_uart_pcm_ring_count > g_uart_pcm_ring_peak) {
        g_uart_pcm_ring_peak = g_uart_pcm_ring_count;
    }
    LOS_IntRestore(intSave);

    if (written > 0U && g_uart_pcm_sem_ready) {
        (void)LOS_SemPost(g_uart_pcm_sem);
    }
    return written;
}

static uint32_t UartLinkPcmRingWriteBlocking(const int16_t *pcm, uint32_t samples, const char *reason)
{
    uint32_t written = 0;
    uint32_t waitMs = 0;

    while (written < samples && waitMs < OHOS_UART_PCM_WRITE_WAIT_MS) {
        uint32_t n = UartLinkPcmRingWriteOnce(&pcm[written], samples - written);
        written += n;
        if (written >= samples) {
            break;
        }
        OhosLiteosDelayMs(OHOS_UART_PCM_WRITE_POLL_MS);
        waitMs += OHOS_UART_PCM_WRITE_POLL_MS;
    }

    if (written == samples) {
        if (waitMs > 0U) {
            g_uart_downlink_pcm_wait_ms += waitMs;
        }
        g_uart_pcm_ring_write_ok++;
        if (g_uart_pcm_ring_write_ok <= 3U ||
            (g_uart_pcm_ring_write_ok % 200U) == 0U ||
            (samples == OHOS_OPUS_UPLINK_PCM_SAMPLES &&
             (g_uart_pcm_ring_write_ok % 20U) == 0U)) {
            esp_rom_printf("[WS63-UART-PCM] push ok samples=%u level=%u free=%u peak=%u writeOk=%u reason=%s\n",
                           samples,
                           UartLinkPcmRingLevelSamples(),
                           UartLinkPcmRingFreeSamples(),
                           g_uart_pcm_ring_peak,
                           g_uart_pcm_ring_write_ok,
                           reason ? reason : "-");
        }
        return 0;
    }

    g_uart_pcm_ring_write_fail++;
    g_uart_pcm_ring_overflow++;
    esp_rom_printf("[WS63-UART-PCM] push fail samples=%u written=%u level=%u free=%u wait=%u overflow=%u fail=%u reason=%s\n",
                   samples,
                   written,
                   UartLinkPcmRingLevelSamples(),
                   UartLinkPcmRingFreeSamples(),
                   waitMs,
                   g_uart_pcm_ring_overflow,
                   g_uart_pcm_ring_write_fail,
                   reason ? reason : "-");
    return 1;
}

static void UartLinkPcmApplyGainInPlace(int16_t *pcm, uint32_t samples, uint32_t gain)
{
    if (pcm == NULL || samples == 0U || gain <= 1U) {
        return;
    }

    for (uint32_t i = 0; i < samples; ++i) {
        int32_t v = (int32_t)pcm[i] * (int32_t)gain;
        if (v > 32767) {
            v = 32767;
        } else if (v < -32768) {
            v = -32768;
        }
        pcm[i] = (int16_t)v;
    }
}

static uint32_t UartLinkPcmPeakAbs(const int16_t *pcm, uint32_t samples)
{
    uint32_t peak = 0;

    if (pcm == NULL || samples == 0U) {
        return 0;
    }

    for (uint32_t i = 0; i < samples; ++i) {
        int32_t v = pcm[i];
        uint32_t av = (uint32_t)((v < 0) ? -v : v);
        if (av > peak) {
            peak = av;
        }
    }

    return peak;
}

static uint32_t UartLinkPcmRingRead(int16_t *out, uint32_t samples)
{
    uint32_t intSave;
    uint32_t read = 0;

    if (g_uart_pcm_ring == NULL || g_uart_pcm_ring_capacity == 0U ||
        out == NULL || samples == 0U) {
        return 0;
    }

    intSave = LOS_IntLock();
    while (read < samples && g_uart_pcm_ring_count > 0U) {
        out[read] = g_uart_pcm_ring[g_uart_pcm_read_idx];
        g_uart_pcm_read_idx = (g_uart_pcm_read_idx + 1U) % g_uart_pcm_ring_capacity;
        g_uart_pcm_ring_count--;
        read++;
    }
    LOS_IntRestore(intSave);

    if (read > 0U) {
        g_uart_pcm_ring_read_ok++;
    }
    return read;
}

static UINT32 UartLinkCreateExternalStackTask(const char *name,
                                              TSK_ENTRY_FUNC entry,
                                              UINT32 arg,
                                              UINT16 prio,
                                              UINT32 stackSize,
                                              UINT32 *taskId)
{
    void *stackMem;
    TSK_INIT_PARAM_S task = {0};
    UINT32 localTaskId = 0;
    UINT32 ret;

    if (entry == NULL) {
        return 1U;
    }

    stackMem = heap_caps_aligned_alloc(OHOS_UART_TASK_STACK_ALIGN,
                                       stackSize,
                                       MALLOC_CAP_SPIRAM | MALLOC_CAP_8BIT);
    if (stackMem == NULL) {
        esp_rom_printf("[WS63-UART-TASK] external stack alloc fail name=%s size=0x%x\n",
                       name ? name : "-",
                       stackSize);
        return 2U;
    }

    memset(stackMem, 0xA5, stackSize);
    task.pfnTaskEntry = entry;
    task.uwStackSize = stackSize;
    task.usTaskPrio = prio;
    task.pcName = (CHAR *)(name ? name : "uart_task");
    task.uwArg = arg;
    task.stackAddr = (UINTPTR)stackMem;

    ret = LOS_TaskCreate(&localTaskId, &task);
    esp_rom_printf("[WS63-UART-TASK] create external name=%s stack=%p size=0x%x ret=%u taskId=%u prio=%u\n",
                   name ? name : "-",
                   stackMem,
                   stackSize,
                   ret,
                   localTaskId,
                   prio);
    if (ret != LOS_OK) {
        heap_caps_free(stackMem);
        localTaskId = 0;
    }

    if (taskId != NULL) {
        *taskId = localTaskId;
    }
    return ret;
}

static void UartLinkOpusQueueInit(void)
{
    if (g_uart_opus_queue != NULL && g_uart_opus_queue_capacity > 0U) {
        return;
    }

    size_t bytes = sizeof(UartLinkOpusQueueSlot) * OHOS_UART_OPUS_QUEUE_DEPTH;
    g_uart_opus_queue = (UartLinkOpusQueueSlot *)heap_caps_calloc(OHOS_UART_OPUS_QUEUE_DEPTH,
                                                                  sizeof(UartLinkOpusQueueSlot),
                                                                  MALLOC_CAP_SPIRAM | MALLOC_CAP_8BIT);
    if (g_uart_opus_queue != NULL) {
        g_uart_opus_queue_capacity = OHOS_UART_OPUS_QUEUE_DEPTH;
        esp_rom_printf("[WS63-UART-OPUS] queue psram ok depth=%u bytes=%u ptr=%p\n",
                       g_uart_opus_queue_capacity,
                       (unsigned)bytes,
                       g_uart_opus_queue);
        return;
    }

    memset(g_uart_opus_queue_fallback, 0, sizeof(g_uart_opus_queue_fallback));
    g_uart_opus_queue = g_uart_opus_queue_fallback;
    g_uart_opus_queue_capacity = (uint32_t)(sizeof(g_uart_opus_queue_fallback) /
