    esp_rom_printf("[WS63-UART-OPUS] queue psram fail fallback depth=%u bytes=%u\n",
                   g_uart_opus_queue_capacity,
                   (unsigned)sizeof(g_uart_opus_queue_fallback));
}

static uint32_t UartLinkUplinkWaitCaptureStartLevel(uint32_t targetSamples,
                                                    uint32_t maxWaitMs)
{
    uint32_t waited = 0;

    while (g_uart_up_opus_running &&
           !g_uart_up_opus_stop_req &&
           OhosAudioEs7210GetUplinkCaptureLevel() < targetSamples &&
           waited < maxWaitMs) {
        uint32_t step = maxWaitMs - waited;
        if (step > OHOS_UART_UP_OPUS_STOP_POLL_MS) {
            step = OHOS_UART_UP_OPUS_STOP_POLL_MS;
        }
        OhosLiteosDelayMs(step);
        waited += step;
    }

    if (OhosAudioEs7210GetUplinkCaptureLevel() >= targetSamples) {
        ESP_LOGI("WS63-UART-UP-OPUS",
                 "capture prefill ok level=%u target=%u wait=%u",
                 OhosAudioEs7210GetUplinkCaptureLevel(),
                 targetSamples,
                 waited);
        return 1;
    }

    ESP_LOGW("WS63-UART-UP-OPUS",
             "capture prefill short level=%u target=%u wait=%u running=%u stop=%u",
             OhosAudioEs7210GetUplinkCaptureLevel(),
             targetSamples,
             waited,
             g_uart_up_opus_running,
             g_uart_up_opus_stop_req);
    return 0;
}

