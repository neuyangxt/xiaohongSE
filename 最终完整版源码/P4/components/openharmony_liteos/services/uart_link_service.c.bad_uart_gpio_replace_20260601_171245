static uint32_t UartLinkDriverInit(void)
{
    uart_config_t uart_config = {
        .baud_rate = OHOS_UART_LINK_BAUDRATE,
        .data_bits = UART_DATA_8_BITS,
        .parity = UART_PARITY_DISABLE,
        .stop_bits = UART_STOP_BITS_1,
        .flow_ctrl = UART_HW_FLOWCTRL_DISABLE,
        .rx_flow_ctrl_thresh = 0,
        .source_clk = UART_SCLK_DEFAULT,
    };

    esp_err_t paramRet = uart_param_config(OHOS_UART_LINK_PORT, &uart_config);
    esp_err_t pinRet = uart_set_pin(OHOS_UART_LINK_PORT,
                                    OHOS_UART_LINK_TX_GPIO,
                                    OHOS_UART_LINK_RX_GPIO,
                                    UART_PIN_NO_CHANGE,
                                    UART_PIN_NO_CHANGE);

    /*
     * If the driver was already installed from a previous test run,
     * uart_driver_install may return an error. Delete once and retry.
     */
    esp_err_t installRet = uart_driver_install(OHOS_UART_LINK_PORT,
                                               OHOS_UART_LINK_RX_BUF_SIZE,
                                               OHOS_UART_LINK_TX_BUF_SIZE,
                                               0,
                                               NULL,
                                               0);
    if (installRet != ESP_OK) {
        uart_driver_delete(OHOS_UART_LINK_PORT);
        installRet = uart_driver_install(OHOS_UART_LINK_PORT,
                                         OHOS_UART_LINK_RX_BUF_SIZE,
                                         OHOS_UART_LINK_TX_BUF_SIZE,
                                         0,
                                         NULL,
                                         0);
    }

    uart_flush_input(OHOS_UART_LINK_PORT);

    g_uart_driver_init_ok = (paramRet == ESP_OK &&
                             pinRet == ESP_OK &&
                             installRet == ESP_OK);

    esp_rom_printf("[OHOS-S46A] UartLinkService driver init uart=%d tx=%d rx=%d baud=%u paramRet=%d pinRet=%d installRet=%d initOk=%u\n",
                   OHOS_UART_LINK_PORT,
                   OHOS_UART_LINK_TX_GPIO,
                   OHOS_UART_LINK_RX_GPIO,
                   OHOS_UART_LINK_BAUDRATE,
                   paramRet,
                   pinRet,
                   installRet,
                   g_uart_driver_init_ok);

    return g_uart_driver_init_ok;
}

static uint32_t UartLinkLoopbackTest(void)
{
    const char *tx = "OHOS_UART_LOOPBACK_S46A";
    char rx[64] = {0};

    uart_flush_input(OHOS_UART_LINK_PORT);

    g_uart_write_ret = uart_write_bytes(OHOS_UART_LINK_PORT, tx, strlen(tx));

    /*
     * Give UART enough time to transmit and receive through external TX-RX jumper.
     */
    LOS_TaskDelay(10);

    g_uart_read_ret = uart_read_bytes(OHOS_UART_LINK_PORT,
                                      rx,
                                      sizeof(rx) - 1,
                                      50);

    if (g_uart_read_ret > 0) {
        rx[g_uart_read_ret] = '\0';
    }

    g_uart_loopback_ok = (g_uart_write_ret == (int32_t)strlen(tx) &&
                          g_uart_read_ret == (int32_t)strlen(tx) &&
                          strcmp(tx, rx) == 0);

    esp_rom_printf("[OHOS-S46A] UartLinkService loopback write=%d read=%d tx=\"%s\" rx=\"%s\" loopOk=%u\n",
                   g_uart_write_ret,
                   g_uart_read_ret,
                   tx,
                   rx,
                   g_uart_loopback_ok);

    return g_uart_loopback_ok;
}


static void UartLinkHandleRxFrame(const OhosUartProtoFrame *frame)
{
    if (frame == NULL) {
        return;
    }

    g_uart_rx_frame_count++;
    g_uart_last_rx_cmd = frame->cmd_type;

    if (frame->cmd_type == OHOS_UART_CMD_QUERY_SYSTEM_STATUS) {
        esp_rom_printf("[OHOS-S47H] rx query cmd=0x%04x name=%s len=%u frameCnt=%u\n",
                       frame->cmd_type,
                       OhosUartProtoCmdName(frame->cmd_type),
                       frame->payload_len,
                       g_uart_rx_frame_count);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_REPORT_SYSTEM_STATUS) {
        uint32_t status = 0xFFFFFFFFU;

        if (frame->payload_len > 0 && frame->payload != NULL) {
            status = frame->payload[0];
        }

        g_uart_last_system_status = status;
        g_uart_link_ready = (status == 0U);

        esp_rom_printf("[OHOS-S47E] rx frame cmd=0x%04x name=%s len=%u status=%u linkReady=%u frameCnt=%u\n",
                       frame->cmd_type,
                       OhosUartProtoCmdName(frame->cmd_type),
                       frame->payload_len,
                       status,
                       g_uart_link_ready,
                       g_uart_rx_frame_count);
        return;
    }

    esp_rom_printf("[OHOS-S47E] rx frame cmd=0x%04x name=%s len=%u frameCnt=%u\n",
                   frame->cmd_type,
                   OhosUartProtoCmdName(frame->cmd_type),
                   frame->payload_len,
                   g_uart_rx_frame_count);
}

static VOID *OhosUartLinkServiceRxTask(UINT32 arg)
{
    (void)arg;

    uint8_t stream[OHOS_UART_RX_STREAM_CAP];
    uint16_t streamLen = 0;

    uint32_t ready = OhosServiceWaitReady(&g_uart_service_init_count,
                                          &g_uart_service_identity,
                                          500);

    if (!ready || !g_uart_driver_init_ok) {
        esp_rom_printf("[OHOS-S47E] UartLinkService rx task wait ready=%u driverInit=%u, continue polling\n",
                       ready,
                       g_uart_driver_init_ok);
    }

    while (!g_uart_driver_init_ok) {
        LOS_TaskDelay(10);
    }

    g_uart_rx_task_started = 1;

    esp_rom_printf("[OHOS-S47E] UartLinkService rx task entered uart=%d cap=%u\n",
                   OHOS_UART_LINK_PORT,
                   OHOS_UART_RX_STREAM_CAP);

    while (1) {
        int readLen;
        uint16_t freeLen;

        if (streamLen >= OHOS_UART_RX_STREAM_CAP) {
            streamLen = 0;
        }

        freeLen = (uint16_t)(OHOS_UART_RX_STREAM_CAP - streamLen);
        readLen = uart_read_bytes(OHOS_UART_LINK_PORT,
                                  &stream[streamLen],
                                  freeLen,
                                  20);

        if (readLen > 0) {
            streamLen = (uint16_t)(streamLen + (uint16_t)readLen);

            while (streamLen >= OHOS_UART_PROTO_FRAME_FIXED_LEN) {
                uint16_t frameOffset = 0;
                uint16_t frameLen = 0;
                OhosUartProtoFrame frame;
                int ret = OhosUartProtoFindFrame(stream,
                                                 streamLen,
                                                 &frameOffset,
                                                 &frameLen,
                                                 &frame,
                                                 0);

                if (ret == OHOS_UART_PROTO_OK) {
                    uint16_t consumeLen = (uint16_t)(frameOffset + frameLen);

                    UartLinkHandleRxFrame(&frame);

                    if (consumeLen < streamLen) {
                        memmove(stream, &stream[consumeLen], streamLen - consumeLen);
                        streamLen = (uint16_t)(streamLen - consumeLen);
                    } else {
                        streamLen = 0;
                    }

                    continue;
                }

                if (ret == OHOS_UART_PROTO_ERR_SHORT) {
                    if (frameOffset > 0 && frameOffset < streamLen) {
                        memmove(stream, &stream[frameOffset], streamLen - frameOffset);
                        streamLen = (uint16_t)(streamLen - frameOffset);
                    }
                    break;
                }

                /*
                 * No valid head or bad frame in current buffer.
                 * Keep the last 3 bytes to allow a split frame head across reads.
                 */
                if (streamLen > 3U) {
                    memmove(stream, &stream[streamLen - 3U], 3U);
                    streamLen = 3U;
                }
                break;
            }
        } else {
            LOS_TaskDelay(1);
        }
    }

    return NULL;
}

static BOOL UartLinkServiceInitialize(Service *service, Identity identity)
{
    (void)service;

    g_uart_service_init_count++;
    g_uart_service_identity = identity;
    g_uart_service_queue_ok = (identity.queueId != NULL);

    uint32_t initOk = UartLinkDriverInit();

    esp_rom_printf("[OHOS-S46A] UartLinkService init count=%u serviceId=%d featureId=%d queue=%p queueOk=%u driverInit=%u\n",
                   g_uart_service_init_count,
                   identity.serviceId,
                   identity.featureId,
                   identity.queueId,
                   g_uart_service_queue_ok,
                   initOk);

    return TRUE;
}

static BOOL UartLinkServiceMessageHandle(Service *service, Request *request)
{
    (void)service;

    g_uart_service_msg_count++;

    BOOL reqOk = FALSE;
    int msgId = request ? request->msgId : -1;
    uint32_t cmd = request ? request->msgValue : 0xffffffffU;

    if (request != NULL) {
        if (request->msgId == OHOS_SERVICE_MSG_UART_GET_STATUS &&
            request->msgValue == OHOS_SERVICE_CMD_GET_STATUS) {
            g_uart_service_status_ok = g_uart_driver_init_ok;
            reqOk = TRUE;
        } else if (request->msgId == OHOS_SERVICE_MSG_UART_SELF_TEST &&
                   request->msgValue == OHOS_SERVICE_CMD_SELF_TEST) {
            g_uart_service_selftest_ok = UartLinkLoopbackTest();
            reqOk = TRUE;
        } else if (request->msgId == OHOS_SERVICE_MSG_UART_SEND) {
            g_uart_service_send_msg_ok = UartLinkLoopbackTest();
            reqOk = TRUE;
        }
    }

    esp_rom_printf("[OHOS-S46A] UartLinkService message count=%u req=%p msgId=%d cmd=%u reqOk=%u statusOk=%u selfTestOk=%u sendMsgOk=%u driverInit=%u loopOk=%u\n",
                   g_uart_service_msg_count,
                   request,
                   msgId,
                   cmd,
                   reqOk,
                   g_uart_service_status_ok,
                   g_uart_service_selftest_ok,
                   g_uart_service_send_msg_ok,
                   g_uart_driver_init_ok,
                   g_uart_loopback_ok);

    return TRUE;
}

static TaskConfig UartLinkServiceGetTaskConfig(Service *service)
{
    (void)service;

    TaskConfig config = {
        .level = LEVEL_HIGH,
        .priority = PRI_NORMAL,
        .stackSize = 0x1000,
        .queueSize = 8,
        .taskFlags = SINGLE_TASK,
    };

    return config;
}

static Service g_uart_link_service = {
    .GetName = UartLinkServiceGetName,
    .Initialize = UartLinkServiceInitialize,
    .MessageHandle = UartLinkServiceMessageHandle,
    .GetTaskConfig = UartLinkServiceGetTaskConfig,
};

static int32 UartLinkServiceSendRequest(int16 msgId, uint32_t cmd)
{
    return OhosServiceSendSimpleRequest(&g_uart_service_identity, msgId, cmd);
}

static VOID *OhosUartLinkServiceVerifyTask(UINT32 arg)
{
    (void)arg;

    for (int i = 0; i < 200; ++i) {
        if (g_uart_service_init_count > 0 && g_uart_service_identity.queueId != NULL) {
            break;
        }
        LOS_TaskDelay(1);
    }

    BOOL initOk = (g_uart_service_init_count > 0);
    BOOL queueOk = (g_uart_service_identity.queueId != NULL);

    int32 statusRet = EC_FAILURE;
    int32 selfTestRet = EC_FAILURE;
    int32 sendRet = EC_FAILURE;

    if (initOk && queueOk) {
        statusRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_GET_STATUS,
                                               OHOS_SERVICE_CMD_GET_STATUS);
        LOS_TaskDelay(20);

        selfTestRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_SELF_TEST,
                                                 OHOS_SERVICE_CMD_SELF_TEST);
        LOS_TaskDelay(20);

        sendRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_SEND,
                                             OHOS_SERVICE_CMD_START);
    }

    g_uart_service_send_ok = (statusRet == EC_SUCCESS &&
                              selfTestRet == EC_SUCCESS &&
                              sendRet == EC_SUCCESS);

    esp_rom_printf("[OHOS-S46A] UartLinkService send status=%d selfTest=%d send=%d sendOk=%u initOk=%u queueOk=%u\n",
                   statusRet,
                   selfTestRet,
                   sendRet,
                   g_uart_service_send_ok,
                   initOk,
                   queueOk);

    for (int i = 0; i < 200; ++i) {
        if (g_uart_service_msg_count >= 3 &&
            g_uart_service_status_ok &&
            g_uart_service_selftest_ok &&
            g_uart_service_send_msg_ok) {
            break;
        }
        LOS_TaskDelay(1);
    }

    BOOL msgOk = (g_uart_service_msg_count >= 3 &&
                  g_uart_service_status_ok &&
                  g_uart_service_selftest_ok &&
                  g_uart_service_send_msg_ok);

    BOOL ok = (initOk &&
               queueOk &&
               g_uart_service_send_ok &&
               msgOk &&
               g_uart_driver_init_ok &&
               g_uart_loopback_ok);

    esp_rom_printf("[OHOS-S46A] UartLinkService verify init=%u queue=%u send=%u msg=%u msgCnt=%u status=%u selfTest=%u sendMsg=%u driverInit=%u loopOk=%u ok=%u\n",
                   initOk,
                   queueOk,
                   g_uart_service_send_ok,
                   msgOk,
                   g_uart_service_msg_count,
                   g_uart_service_status_ok,
                   g_uart_service_selftest_ok,
                   g_uart_service_send_msg_ok,
                   g_uart_driver_init_ok,
                   g_uart_loopback_ok,
                   ok);

    return NULL;
}



uint32_t OhosUartLinkServiceLegacySelfTest(void)
{
    uint32_t ready = OhosServiceWaitReady(&g_uart_service_init_count,
                                          &g_uart_service_identity,
                                          200);
    uint32_t baseMsgCnt = g_uart_service_msg_count;

    int32 statusRet = EC_FAILURE;
    int32 selfTestRet = EC_FAILURE;
    int32 sendRet = EC_FAILURE;

    if (ready) {
        statusRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_GET_STATUS,
                                               OHOS_SERVICE_CMD_GET_STATUS);
        LOS_TaskDelay(20);

        selfTestRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_SELF_TEST,
                                                 OHOS_SERVICE_CMD_SELF_TEST);
        LOS_TaskDelay(20);

        sendRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_SEND,
                                             OHOS_SERVICE_CMD_START);
    }

    for (int i = 0; i < 200; ++i) {
        if (g_uart_service_msg_count >= baseMsgCnt + 3 &&
            g_uart_loopback_ok) {
            break;
        }
        LOS_TaskDelay(1);
    }

    uint32_t msgOk = (g_uart_service_msg_count >= baseMsgCnt + 3);
    uint32_t sendOk = (statusRet == EC_SUCCESS &&
                       selfTestRet == EC_SUCCESS &&
                       sendRet == EC_SUCCESS);
    uint32_t ok = (ready && sendOk && msgOk && g_uart_driver_init_ok && g_uart_loopback_ok);

    esp_rom_printf("[OHOS-S46A] UartLinkService selftest ready=%u send=%u msg=%u driverInit=%u loopOk=%u base=%u now=%u ok=%u\n",
                   ready,
                   sendOk,
                   msgOk,
                   g_uart_driver_init_ok,
                   g_uart_loopback_ok,
                   baseMsgCnt,
                   g_uart_service_msg_count,
                   ok);

    return ok ? LOS_OK : 1U;
}




static uint32_t UartLinkSendProtocolFrame(uint16_t cmdType,
                                          const uint8_t *payload,
                                          uint16_t payloadLen,
                                          const char *tag)
{
    uint8_t frame[OHOS_UART_PROTO_FRAME_FIXED_LEN + 64U];
    uint16_t frameLen = 0;
    int encodeRet;
    int writeRet;
    uint32_t ok;

    if (payloadLen > 64U) {
        esp_rom_printf("[OHOS-S47H] tx frame tag=%s cmd=0x%04x payload too large len=%u\n",
                       tag ? tag : "null",
                       cmdType,
                       payloadLen);
        return 0;
    }

    encodeRet = OhosUartProtoEncode(cmdType,
                                    payload,
                                    payloadLen,
                                    frame,
                                    sizeof(frame),
                                    &frameLen,
                                    0);

    if (encodeRet != OHOS_UART_PROTO_OK) {
        esp_rom_printf("[OHOS-S47H] tx frame tag=%s cmd=0x%04x encodeRet=%d ok=0\n",
                       tag ? tag : "null",
                       cmdType,
                       encodeRet);
        return 0;
    }

    writeRet = uart_write_bytes(OHOS_UART_LINK_PORT, frame, frameLen);
    ok = (writeRet == (int)frameLen);

    esp_rom_printf("[OHOS-S47H] tx frame tag=%s cmd=0x%04x name=%s payloadLen=%u frameLen=%u writeRet=%d ok=%u\n",
                   tag ? tag : "null",
                   cmdType,
                   OhosUartProtoCmdName(cmdType),
                   payloadLen,
                   frameLen,
                   writeRet,
                   ok);

    return ok;
}

static VOID *OhosUartLinkServiceHandshakeTask(UINT32 arg)
{
    (void)arg;

    uint32_t ready = OhosServiceWaitReady(&g_uart_service_init_count,
                                          &g_uart_service_identity,
                                          500);

    if (!ready) {
        esp_rom_printf("[OHOS-S47H] handshake task wait service ready failed\n");
    }

    while (!g_uart_driver_init_ok || !g_uart_rx_task_started) {
        LOS_TaskDelay(10);
    }

    g_uart_handshake_task_started = 1;

    esp_rom_printf("[OHOS-S47H] handshake task entered retry=%u linkReady=%u\n",
                   OHOS_UART_HANDSHAKE_MAX_RETRY,
                   g_uart_link_ready);

    for (uint32_t i = 0; i < OHOS_UART_HANDSHAKE_MAX_RETRY; ++i) {
        uint32_t txOk;

        if (g_uart_link_ready) {
            break;
        }

        txOk = UartLinkSendProtocolFrame(OHOS_UART_CMD_QUERY_SYSTEM_STATUS,
                                         NULL,
                                         0,
                                         "QUERY_SYSTEM_STATUS");

        g_uart_query_tx_count++;
        if (txOk) {
            g_uart_query_tx_ok++;
        }

        esp_rom_printf("[OHOS-S47H] handshake query attempt=%u txOk=%u queryCnt=%u queryOk=%u linkReady=%u\n",
                       i + 1,
                       txOk,
                       g_uart_query_tx_count,
                       g_uart_query_tx_ok,
                       g_uart_link_ready);

        for (uint32_t wait = 0; wait < OHOS_UART_HANDSHAKE_WAIT_TICKS; ++wait) {
            if (g_uart_link_ready) {
                break;
            }
            LOS_TaskDelay(5);
        }
    }

    g_uart_handshake_task_done = 1;

    esp_rom_printf("[OHOS-S47H] handshake task done queryCnt=%u queryOk=%u linkReady=%u lastCmd=0x%04x status=%u\n",
                   g_uart_query_tx_count,
                   g_uart_query_tx_ok,
                   g_uart_link_ready,
                   g_uart_last_rx_cmd,
                   g_uart_last_system_status);

    return NULL;
}


static uint32_t UartLinkProtocolLoopbackTest(void)
{
#if OHOS_UART_LINK_ENABLE_PROTOCOL_LOOPBACK_SELFTEST
    uint8_t payload[1] = {0};
    uint8_t frame[OHOS_UART_PROTO_FRAME_FIXED_LEN + 1U];
    uint16_t frameLen = 0;
    int encodeRet;
    int writeRet;
    uint32_t baseFrameCnt;
    uint32_t ready = 0;
    uint32_t ok;

    for (int i = 0; i < 100; ++i) {
        if (g_uart_driver_init_ok && g_uart_rx_task_started) {
            ready = 1;
            break;
        }
        LOS_TaskDelay(1);
    }

    encodeRet = OhosUartProtoEncode(OHOS_UART_CMD_REPORT_SYSTEM_STATUS,
                                    payload,
                                    1,
                                    frame,
                                    sizeof(frame),
                                    &frameLen,
                                    0);

    if (encodeRet != OHOS_UART_PROTO_OK) {
        esp_rom_printf("[OHOS-S47F] protocol loopback encode failed ret=%d\n", encodeRet);
        return 0;
    }

    baseFrameCnt = g_uart_rx_frame_count;
    g_uart_link_ready = 0;
    g_uart_last_rx_cmd = 0;
    g_uart_last_system_status = 0xFFFFFFFFU;

    uart_flush_input(OHOS_UART_LINK_PORT);

    writeRet = uart_write_bytes(OHOS_UART_LINK_PORT, frame, frameLen);

    for (int i = 0; i < 200; ++i) {
        if (g_uart_rx_frame_count > baseFrameCnt &&
            g_uart_last_rx_cmd == OHOS_UART_CMD_REPORT_SYSTEM_STATUS &&
            g_uart_link_ready) {
            break;
        }
        LOS_TaskDelay(1);
    }

    ok = (ready &&
          writeRet == (int)frameLen &&
          g_uart_rx_frame_count > baseFrameCnt &&
          g_uart_last_rx_cmd == OHOS_UART_CMD_REPORT_SYSTEM_STATUS &&
          g_uart_last_system_status == 0U &&
          g_uart_link_ready);

    esp_rom_printf("[OHOS-S47F] UartLinkService protocol loopback ready=%u tx=%d frameLen=%u base=%u now=%u lastCmd=0x%04x status=%u linkReady=%u ok=%u\n",
                   ready,
                   writeRet,
                   frameLen,
                   baseFrameCnt,
                   g_uart_rx_frame_count,
                   g_uart_last_rx_cmd,
                   g_uart_last_system_status,
                   g_uart_link_ready,
                   ok);

    return ok;
#else
    esp_rom_printf("[OHOS-S47G] UartLinkService protocol loopback skipped by config\n");
    return 1U;
#endif
}


uint32_t OhosUartLinkServiceSelfTest(void)
{
    int protoRet = OhosUartProtoSelfTest();
    int protoOk = (protoRet == OHOS_UART_PROTO_OK);
    uint32_t loopOk;

#if OHOS_UART_LINK_ENABLE_REAL_WS63_MODE
    loopOk = 1U;
    esp_rom_printf("[OHOS-S47I] real WS63 mode enabled, local protocol loopback is skipped\n");
#else
    loopOk = UartLinkProtocolLoopbackTest();
#endif

    uint32_t ok = (protoOk && loopOk);

    esp_rom_printf("[OHOS-S47I] UartLinkService link mode realWs63=%u localLoopback=%u baud=%u protoRet=%d protoOk=%d loopOk=%u linkReady=%u queryCnt=%u queryOk=%u ok=%u\n",
                   (uint32_t)OHOS_UART_LINK_ENABLE_REAL_WS63_MODE,
                   (uint32_t)OHOS_UART_LINK_ENABLE_PROTOCOL_LOOPBACK_SELFTEST,
                   (uint32_t)OHOS_UART_LINK_BAUDRATE,
                   protoRet,
                   protoOk,
                   loopOk,
                   g_uart_link_ready,
                   g_uart_query_tx_count,
                   g_uart_query_tx_ok,
                   ok);

    return ok ? 0 : 1;
}



uint32_t OhosUartLinkServiceRegister(void)
{
    SamgrLite *samgr = SAMGR_GetInstance();

    if (samgr == NULL) {
        esp_rom_printf("[OHOS-S46A] UartLinkService register failed: samgr null\n");
        return 1U;
    }

    BOOL regOk = samgr->RegisterService(&g_uart_link_service);

    esp_rom_printf("[OHOS-S46A] UartLinkService register regOk=%u\n", regOk);

    return (regOk == TRUE) ? LOS_OK : 2U;
}

uint32_t OhosUartLinkServiceStartTasks(void)
{
    int protoSelfRet = OhosUartProtoSelfTest();
    esp_rom_printf("[OHOS-S47B] UartLinkService proto selftest ret=%d ok=%d\n",
                   protoSelfRet, protoSelfRet == OHOS_UART_PROTO_OK);

    TSK_INIT_PARAM_S rxTask = {0};
    rxTask.pfnTaskEntry = (TSK_ENTRY_FUNC)OhosUartLinkServiceRxTask;
    rxTask.uwStackSize = OHOS_UART_RX_TASK_STACK;
    rxTask.usTaskPrio = OHOS_UART_RX_TASK_PRIO;
    rxTask.pcName = "ohos_uart_rx";
    uint32_t rxRet = LOS_TaskCreate(&g_uart_rx_task_id, &rxTask);
    esp_rom_printf("[OHOS-S47E] UartLinkService rx task create ret=%u taskId=%u prio=%u stack=0x%x\n",
                   rxRet,
                   g_uart_rx_task_id,
                   OHOS_UART_RX_TASK_PRIO,
                   OHOS_UART_RX_TASK_STACK);

    TSK_INIT_PARAM_S handshakeTask = {0};
    handshakeTask.pfnTaskEntry = (TSK_ENTRY_FUNC)OhosUartLinkServiceHandshakeTask;
    handshakeTask.uwStackSize = OHOS_UART_HANDSHAKE_TASK_STACK;
    handshakeTask.usTaskPrio = OHOS_UART_HANDSHAKE_TASK_PRIO;
    handshakeTask.pcName = "ohos_uart_hs";
    uint32_t hsRet = LOS_TaskCreate(&g_uart_handshake_task_id, &handshakeTask);
    esp_rom_printf("[OHOS-S47H] UartLinkService handshake task create ret=%u taskId=%u prio=%u stack=0x%x\n",
                   hsRet,
                   g_uart_handshake_task_id,
                   OHOS_UART_HANDSHAKE_TASK_PRIO,
                   OHOS_UART_HANDSHAKE_TASK_STACK);

    esp_rom_printf("[OHOS-S46A] UartLinkService standalone verify task skipped, unified selftest will run\n");
    return LOS_OK;
}

uint32_t OhosUartLinkServiceStart(void)
{
    uint32_t ret = OhosUartLinkServiceRegister();

    if (ret != LOS_OK) {
        return ret;
    }

    SAMGR_Bootstrap();

    ret = OhosUartLinkServiceStartTasks();

    return ret;
}

