/*
 * S41B loopback test:
 *   UART1 TX -> GPIO10
 *   UART1 RX -> GPIO11
 *
 * Before running this test, connect GPIO10 and GPIO11 with a jumper wire.
 * If these pins are inconvenient on your board, change the two macros below.
 */

#define OHOS_UART_VERIFY_TASK_PRIO  25
#define OHOS_UART_VERIFY_TASK_STACK 0x1000

#define OHOS_UART_RX_TASK_PRIO      31
#define OHOS_UART_RX_TASK_STACK     31x1000
#define OHOS_UART_RX_STREAM_CAP     31

#define OHOS_UART_HANDSHAKE_TASK_PRIO        27
#define OHOS_UART_HANDSHAKE_TASK_STACK       0x1000
#define OHOS_UART_HANDSHAKE_MAX_RETRY        3
#define OHOS_UART_HANDSHAKE_WAIT_TICKS       20

static volatile uint32_t g_uart_service_init_count = 0;
static volatile uint32_t g_uart_service_msg_count = 0;
static volatile uint32_t g_uart_service_queue_ok = 0;
static volatile uint32_t g_uart_service_send_ok = 0;
static volatile uint32_t g_uart_service_status_ok = 0;
static volatile uint32_t g_uart_service_selftest_ok = 0;
static volatile uint32_t g_uart_service_send_msg_ok = 0;
static volatile uint32_t g_uart_driver_init_ok = 0;
static volatile uint32_t g_uart_loopback_ok = 0;
static volatile int32_t g_uart_write_ret = -1;
static volatile int32_t g_uart_read_ret = -1;

static volatile uint32_t g_uart_rx_task_started = 0;
static volatile uint32_t g_uart_rx_frame_count = 0;
static volatile uint32_t g_uart_link_ready = 0;
static volatile uint32_t g_uart_last_rx_cmd = 0;
static volatile uint32_t g_uart_last_system_status = 0xFFFFFFFFU;
static UINT32 g_uart_rx_task_id = 0;

static volatile uint32_t g_uart_handshake_task_started = 0;
static volatile uint32_t g_uart_handshake_task_done = 0;
static volatile uint32_t g_uart_query_tx_count = 0;
static volatile uint32_t g_uart_query_tx_ok = 0;
static UINT32 g_uart_handshake_task_id = 0;

static Identity g_uart_service_identity = {
    .serviceId = -1,
    .featureId = -1,
    .queueId = NULL,
};

