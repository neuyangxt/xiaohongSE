static void UartLinkUplinkOpusDelayStopAware(uint32_t totalMs)
{
    uint32_t elapsed = 0;

    while (elapsed < totalMs && g_uart_up_opus_running && !g_uart_up_opus_stop_req) {
        uint32_t step = totalMs - elapsed;
        if (step > OHOS_UART_UP_OPUS_STOP_POLL_MS) {
            step = OHOS_UART_UP_OPUS_STOP_POLL_MS;
        }
        OhosLiteosDelayMs(step);
        elapsed += step;
    }
}

