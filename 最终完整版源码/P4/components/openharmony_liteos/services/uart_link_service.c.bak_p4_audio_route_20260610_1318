}

static void UartLinkHandleDownAudioFrame(const OhosUartProtoFrame *frame)
{
    if (frame == NULL) {
        return;
    }

    g_uart_down_audio_count++;
    g_uart_down_audio_bytes += frame->payload_len;
    g_uart_down_audio_last_len = frame->payload_len;

    if (g_uart_down_audio_count <= 5U || (g_uart_down_audio_count % 20U) == 0U) {
        esp_rom_printf("[WS63-UART-DOWN-AUDIO] count=%u cmd=0x%04x payloadLen=%u totalBytes=%u\n",
                       g_uart_down_audio_count,
                       frame->cmd_type,
                       frame->payload_len,
                       g_uart_down_audio_bytes);
    }

    if (g_uart_down_audio_count <= 3U) {
        UartLinkDumpHex("[WS63-UART-DOWN-AUDIO-RAW]", frame->payload, frame->payload_len);
    }

    UartLinkHandleDownAudioPayload(frame->payload, frame->payload_len);
}

static void UartLinkHandleRxFrame(const OhosUartProtoFrame *frame)
{
    if (frame == NULL) {
        return;
    }

    g_uart_rx_frame_count++;
    g_uart_last_rx_cmd = frame->cmd_type;

    if (frame->cmd_type == OHOS_UART_CMD_QUERY_SYSTEM_STATUS) {
        esp_rom_printf("[OHOS-S47H] rx query cmd=0x%04x name=%s len=%u frameCnt=%u\n",
                       frame->cmd_type,
                       OhosUartProtoCmdName(frame->cmd_type),
                       frame->payload_len,
                       g_uart_rx_frame_count);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_REPORT_SYSTEM_STATUS) {
        uint32_t status = 0xFFFFFFFFU;

        if (frame->payload_len > 0 && frame->payload != NULL) {
            status = frame->payload[0];
        }

        g_uart_last_system_status = status;
        g_uart_link_ready = (status == 0U);

        esp_rom_printf("[OHOS-S47E] rx frame cmd=0x%04x name=%s len=%u status=%u linkReady=%u frameCnt=%u\n",
                       frame->cmd_type,
                       OhosUartProtoCmdName(frame->cmd_type),
                       frame->payload_len,
                       status,
                       g_uart_link_ready,
                       g_uart_rx_frame_count);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_WIFI_SEND_SSID) {
        UartLinkHandleStringData("WIFI_SEND_SSID",
                                 g_uart_wifi_ssid,
                                 OHOS_UART_SMALL_STRING_CAP,
                                 &g_uart_wifi_ssid_len,
                                 frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_WIFI_SEND_PSWD) {
        UartLinkHandleStringData("WIFI_SEND_PSWD",
                                 g_uart_wifi_pswd,
                                 OHOS_UART_SMALL_STRING_CAP,
                                 &g_uart_wifi_pswd_len,
                                 frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_SET_WS_SERVER_URL) {
        UartLinkHandleStringData("SET_WS_SERVER_URL",
                                 g_uart_ws_url,
                                 OHOS_UART_SMALL_STRING_CAP,
                                 &g_uart_ws_url_len,
                                 frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_DOWN_TEXT_DATA) {
        UartLinkHandleDownTextFrame(frame);
        return;
    }

    if (frame->cmd_type == OHOS_UART_CMD_DOWN_AUDIO_DATA) {
        UartLinkHandleDownAudioFrame(frame);
        return;
    }

    esp_rom_printf("[OHOS-S47E] rx frame cmd=0x%04x name=%s len=%u frameCnt=%u\n",
                   frame->cmd_type,
                   OhosUartProtoCmdName(frame->cmd_type),
                   frame->payload_len,
                   g_uart_rx_frame_count);
}

static uint32_t UartLinkParseBufferedStream(uint8_t *stream, uint16_t *streamLen, const char *tag)
{
    uint32_t parsed = 0;

    if (stream == NULL || streamLen == NULL) {
        return 0;
    }

    while (*streamLen >= OHOS_UART_PROTO_FRAME_FIXED_LEN) {
        uint16_t frameOffset = 0;
        uint16_t frameLen = 0;
        OhosUartProtoFrame frame;
        int ret = OhosUartProtoFindFrame(stream,
                                         *streamLen,
                                         &frameOffset,
                                         &frameLen,
                                         &frame,
                                         0);

        if (ret == OHOS_UART_PROTO_OK) {
            uint16_t consumeLen = (uint16_t)(frameOffset + frameLen);

            esp_rom_printf("[%s] parse ok offset=%u frameLen=%u cmd=0x%04x name=%s payloadLen=%u\n",
                           tag ? tag : "WS63-UART-PARSE",
                           frameOffset,
                           frameLen,
                           frame.cmd_type,
                           OhosUartProtoCmdName(frame.cmd_type),
                           frame.payload_len);

            UartLinkHandleRxFrame(&frame);
            parsed++;

            if (consumeLen < *streamLen) {
                memmove(stream, &stream[consumeLen], *streamLen - consumeLen);
                *streamLen = (uint16_t)(*streamLen - consumeLen);
            } else {
                *streamLen = 0;
            }

            continue;
        }

        if (ret == OHOS_UART_PROTO_ERR_SHORT) {
            if (frameOffset > 0U && frameOffset < *streamLen) {
                memmove(stream, &stream[frameOffset], *streamLen - frameOffset);
                *streamLen = (uint16_t)(*streamLen - frameOffset);
            }
            break;
        }

        {
            uint16_t keep = UartLinkKeepPartialHead(stream, *streamLen);
            g_uart_rx_parse_fail_count++;
            esp_rom_printf("[%s] failCnt=%u ret=%d streamLen=%u keep=%u\n",
                           tag ? tag : "WS63-UART-PARSE",
                           g_uart_rx_parse_fail_count,
                           ret,
                           *streamLen,
                           keep);
            UartLinkDumpHex("[WS63-UART-BUF]", stream, *streamLen);

            if (keep > 0U) {
                memmove(stream, &stream[*streamLen - keep], keep);
            }
            *streamLen = keep;
        }
        break;
    }

    return parsed;
}

#if OHOS_UART_LINK_ENABLE_LONG_FRAME_SELFTEST
static uint32_t UartLinkSelftestFeedFrame(uint8_t *stream,
                                          uint16_t *streamLen,
                                          uint16_t cmdType,
                                          const uint8_t *payload,
                                          uint16_t payloadLen,
                                          uint16_t chunk)
{
    uint8_t *frame = g_uart_selftest_frame;
    uint16_t frameLen = 0;
    uint16_t offset = 0;
    uint32_t parsed = 0;
    int ret;

    ret = OhosUartProtoEncode(cmdType,
                              payload,
                              payloadLen,
                              frame,
                              (uint16_t)(OHOS_UART_PROTO_FRAME_FIXED_LEN + 384U),
                              &frameLen,
                              0);
    if (ret != OHOS_UART_PROTO_OK) {
        esp_rom_printf("[WS63-UART-LONG-SELFTEST] encode fail cmd=0x%04x payloadLen=%u ret=%d\n",
                       cmdType,
                       payloadLen,
                       ret);
        return 0;
    }

    while (offset < frameLen) {
        uint16_t part = (uint16_t)(frameLen - offset);
        if (part > chunk) {
            part = chunk;
        }

        if ((uint32_t)(*streamLen + part) > OHOS_UART_RX_STREAM_CAP) {
            esp_rom_printf("[WS63-UART-LONG-SELFTEST] stream overflow cmd=0x%04x streamLen=%u part=%u\n",
                           cmdType,
                           *streamLen,
                           part);
            *streamLen = 0;
            return parsed;
        }

        memcpy(&stream[*streamLen], &frame[offset], part);
        *streamLen = (uint16_t)(*streamLen + part);
        parsed += UartLinkParseBufferedStream(stream, streamLen, "WS63-UART-LONG-SELFTEST");
        offset = (uint16_t)(offset + part);
    }

    esp_rom_printf("[WS63-UART-LONG-SELFTEST] cmd=0x%04x name=%s payloadLen=%u frameLen=%u chunk=%u parsed=%u remain=%u\n",
                   cmdType,
                   OhosUartProtoCmdName(cmdType),
                   payloadLen,
                   frameLen,
                   chunk,
                   parsed,
                   *streamLen);
    return parsed;
}

