static VOID *UartLinkUplinkOpusTask(UINT32 arg)
{
    (void)arg;

    g_uart_up_opus_task_started = 1;
    ESP_LOGI("WS63-UART-UP-OPUS",
             "task start prio=%u stack=0x%x frameMs=%u pcmSamples=%u bitrate=%u targetBytes=%u",
             OHOS_UART_UP_OPUS_TASK_PRIO,
             OHOS_UART_UP_OPUS_TASK_STACK,
             OHOS_OPUS_UPLINK_FRAME_MS,
             OHOS_OPUS_UPLINK_PCM_SAMPLES,
             OHOS_OPUS_UPLINK_BITRATE,
             OHOS_OPUS_UPLINK_TARGET_BYTES);

    while (1) {
        uint16_t opusLen = 0;
        int32_t encRet;
        uint32_t readRet;
        uint32_t txOk;
        OhosAudioEs7210PcmFrameSnapshot pcmSnap;

        if (g_uart_up_opus_stop_req || (!g_uart_up_opus_running && g_uart_up_opus_vad_session_active)) {
            if (g_uart_up_opus_vad_session_active) {
                uint32_t vadEndOk = UartLinkSendUplinkControlFrame(OHOS_UART_CMD_SET_FORCE_VAD_END,
                                                                    "SET_FORCE_VAD_END");
                if (vadEndOk) {
                    g_uart_up_opus_vad_end_ok++;
                    g_uart_up_opus_vad_session_active = 0;
                } else {
                    g_uart_up_opus_vad_end_fail++;
                }
            }
            g_uart_up_opus_running = 0;
            g_uart_up_opus_stop_req = 0;
            ESP_LOGI("WS63-UART-UP-OPUS",
                     "stop acknowledged stopCnt=%u txOk=%u txFail=%u encFail=%u pcmFail=%u vadS=%u/%u vadE=%u/%u",
                     g_uart_up_opus_stop_count,
                     g_uart_up_opus_tx_ok,
                     g_uart_up_opus_tx_fail,
                     g_uart_up_opus_encode_fail,
                     g_uart_up_opus_pcm_fail,
                     g_uart_up_opus_vad_start_ok,
                     g_uart_up_opus_vad_start_fail,
                     g_uart_up_opus_vad_end_ok,
                     g_uart_up_opus_vad_end_fail);
            continue;
        }

        if (!g_uart_up_opus_running) {
            LOS_TaskDelay(5);
            continue;
        }

        if (!g_uart_driver_init_ok || !g_uart_link_ready) {
            g_uart_up_opus_last_ret = 0xfffffffdU;
            if ((g_uart_up_opus_pcm_fail % 25U) == 0U) {
                ESP_LOGI("WS63-UART-UP-OPUS",
                         "wait link driver=%u linkReady=%u running=%u",
                         g_uart_driver_init_ok,
                         g_uart_link_ready,
                         g_uart_up_opus_running);
            }
            g_uart_up_opus_pcm_fail++;
            LOS_TaskDelay(10);
            continue;
        }

        if (!g_uart_up_opus_vad_session_active) {
            uint32_t vadStartOk = UartLinkSendUplinkControlFrame(OHOS_UART_CMD_SET_VAD_START,
                                                                 "SET_VAD_START");
            if (vadStartOk) {
                g_uart_up_opus_vad_start_ok++;
                g_uart_up_opus_vad_session_active = 1;
            } else {
                g_uart_up_opus_vad_start_fail++;
                g_uart_up_opus_last_ret = 0xfffffff0U;
                LOS_TaskDelay(10);
                continue;
            }
        }

        uint32_t frameStartMs = (uint32_t)esp_log_timestamp();

        readRet = OhosAudioEs7210ReadPcm16MonoFrame(g_uart_up_opus_pcm,
                                                    OHOS_OPUS_UPLINK_PCM_SAMPLES,
                                                    120);
        OhosAudioEs7210GetPcmFrameSnapshot(&pcmSnap);
        g_uart_up_opus_last_peak = pcmSnap.peak;
        g_uart_up_opus_last_nonzero = pcmSnap.nonzero;
        g_uart_up_opus_last_samples = OHOS_OPUS_UPLINK_PCM_SAMPLES;

        if (readRet != 0U) {
            g_uart_up_opus_pcm_fail++;
            g_uart_up_opus_last_ret = readRet;
            LOS_TaskDelay(1);
            continue;
        }
        if (!g_uart_up_opus_running || g_uart_up_opus_stop_req) {
            continue;
        }
        g_uart_up_opus_pcm_ok++;

        encRet = OhosOpusEncodePcm16Mono(g_uart_up_opus_pcm,
                                         OHOS_OPUS_UPLINK_PCM_SAMPLES,
                                         g_uart_up_opus_payload,
                                         (uint16_t)sizeof(g_uart_up_opus_payload),
                                         &opusLen);
        if (encRet != 0 || opusLen == 0U) {
            g_uart_up_opus_encode_fail++;
            g_uart_up_opus_last_ret = (uint32_t)encRet;
            LOS_TaskDelay(1);
            continue;
        }
        if (!g_uart_up_opus_running || g_uart_up_opus_stop_req) {
            continue;
        }
        g_uart_up_opus_encode_ok++;
        g_uart_up_opus_last_len = opusLen;

        txOk = UartLinkSendUplinkOpusFrame(g_uart_up_opus_payload, opusLen);
        if (txOk) {
            g_uart_up_opus_tx_ok++;
        } else {
            g_uart_up_opus_tx_fail++;
        }

        if (!txOk ||
            g_uart_up_opus_tx_ok <= 5U ||
            (g_uart_up_opus_tx_ok % 100U) == 0U ||
            opusLen != OHOS_OPUS_UPLINK_TARGET_BYTES) {
            ESP_LOGI("WS63-UART-UP-OPUS",
                     "frame done pcmOk=%u pcmFail=%u encOk=%u encFail=%u txOk=%u txFail=%u opusLen=%u peak=%u nonzero=%u linkReady=%u",
                     g_uart_up_opus_pcm_ok,
                     g_uart_up_opus_pcm_fail,
                     g_uart_up_opus_encode_ok,
                     g_uart_up_opus_encode_fail,
                     g_uart_up_opus_tx_ok,
                     g_uart_up_opus_tx_fail,
                     opusLen,
                     g_uart_up_opus_last_peak,
                     g_uart_up_opus_last_nonzero,
                     g_uart_link_ready);
        }

        uint32_t frameElapsedMs = (uint32_t)(esp_log_timestamp() - frameStartMs);
        if (frameElapsedMs < OHOS_OPUS_UPLINK_FRAME_MS) {
            UartLinkUplinkOpusDelayStopAware(OHOS_OPUS_UPLINK_FRAME_MS - frameElapsedMs);
        }
    }

    return NULL;
}

static void UartLinkUplinkOpusStartTask(void)
{
    if (g_uart_up_opus_task_started || g_uart_up_opus_task_id != 0U) {
        return;
    }

    TSK_INIT_PARAM_S task = {0};
    task.pfnTaskEntry = (TSK_ENTRY_FUNC)UartLinkUplinkOpusTask;
