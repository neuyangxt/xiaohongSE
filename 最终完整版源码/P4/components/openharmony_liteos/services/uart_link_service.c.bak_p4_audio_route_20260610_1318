        ESP_LOGW("WS63-UART-UP-OPUS",
                 "encode frame fail opusLen=%u ret=%d",
                 payloadLen,
                 encodeRet);
        return 0;
    }

    writeRet = uart_write_bytes(OHOS_UART_LINK_PORT, g_uart_up_opus_tx_frame, frameLen);
    ok = (writeRet == (int)frameLen);
    g_uart_up_opus_last_ret = (uint32_t)writeRet;
    if (ok) {
        g_uart_diag_tx_count++;
    }

    if (!ok ||
        g_uart_up_opus_tx_ok < 3U ||
        ((g_uart_up_opus_tx_ok + g_uart_up_opus_tx_fail) % 100U) == 0U) {
        ESP_LOGI("WS63-UART-UP-OPUS",
                 "tx cmd=0x%04x payloadLen=%u frameLen=%u writeRet=%d ok=%u txOk=%u txFail=%u linkReady=%u",
                 OHOS_UART_CMD_UP_AUDIO_DATA,
                 payloadLen,
                 frameLen,
                 writeRet,
                 ok,
                 g_uart_up_opus_tx_ok,
                 g_uart_up_opus_tx_fail,
                 g_uart_link_ready);
    }

    return ok;
}

