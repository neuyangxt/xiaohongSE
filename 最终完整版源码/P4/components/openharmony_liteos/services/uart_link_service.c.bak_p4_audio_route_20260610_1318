static VOID *OhosUartLinkServiceVerifyTask(UINT32 arg)
{
    (void)arg;

    for (int i = 0; i < 200; ++i) {
        if (g_uart_service_init_count > 0 && g_uart_service_identity.queueId != NULL) {
            break;
        }
        LOS_TaskDelay(1);
    }

    BOOL initOk = (g_uart_service_init_count > 0);
    BOOL queueOk = (g_uart_service_identity.queueId != NULL);

    int32 statusRet = EC_FAILURE;
    int32 selfTestRet = EC_FAILURE;
    int32 sendRet = EC_FAILURE;

    if (initOk && queueOk) {
        statusRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_GET_STATUS,
                                               OHOS_SERVICE_CMD_GET_STATUS);
        LOS_TaskDelay(20);

        selfTestRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_SELF_TEST,
                                                 OHOS_SERVICE_CMD_SELF_TEST);
        LOS_TaskDelay(20);

        sendRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_SEND,
                                             OHOS_SERVICE_CMD_START);
    }

    g_uart_service_send_ok = (statusRet == EC_SUCCESS &&
                              selfTestRet == EC_SUCCESS &&
                              sendRet == EC_SUCCESS);

    esp_rom_printf("[OHOS-S46A] UartLinkService send status=%d selfTest=%d send=%d sendOk=%u initOk=%u queueOk=%u\n",
                   statusRet,
                   selfTestRet,
                   sendRet,
                   g_uart_service_send_ok,
                   initOk,
                   queueOk);

    for (int i = 0; i < 200; ++i) {
        if (g_uart_service_msg_count >= 3 &&
            g_uart_service_status_ok &&
            g_uart_service_selftest_ok &&
            g_uart_service_send_msg_ok) {
            break;
        }
        LOS_TaskDelay(1);
    }

    BOOL msgOk = (g_uart_service_msg_count >= 3 &&
                  g_uart_service_status_ok &&
                  g_uart_service_selftest_ok &&
                  g_uart_service_send_msg_ok);

    BOOL ok = (initOk &&
               queueOk &&
               g_uart_service_send_ok &&
               msgOk &&
               g_uart_driver_init_ok &&
               g_uart_loopback_ok);

    esp_rom_printf("[OHOS-S46A] UartLinkService verify init=%u queue=%u send=%u msg=%u msgCnt=%u status=%u selfTest=%u sendMsg=%u driverInit=%u loopOk=%u ok=%u\n",
                   initOk,
                   queueOk,
                   g_uart_service_send_ok,
                   msgOk,
                   g_uart_service_msg_count,
                   g_uart_service_status_ok,
                   g_uart_service_selftest_ok,
                   g_uart_service_send_msg_ok,
                   g_uart_driver_init_ok,
                   g_uart_loopback_ok,
                   ok);

    return NULL;
}



uint32_t OhosUartLinkServiceLegacySelfTest(void)
{
    uint32_t ready = OhosServiceWaitReady(&g_uart_service_init_count,
                                          &g_uart_service_identity,
                                          200);
    uint32_t baseMsgCnt = g_uart_service_msg_count;

    int32 statusRet = EC_FAILURE;
    int32 selfTestRet = EC_FAILURE;
    int32 sendRet = EC_FAILURE;

    if (ready) {
        statusRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_GET_STATUS,
                                               OHOS_SERVICE_CMD_GET_STATUS);
        LOS_TaskDelay(20);

        selfTestRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_SELF_TEST,
                                                 OHOS_SERVICE_CMD_SELF_TEST);
        LOS_TaskDelay(20);

        sendRet = UartLinkServiceSendRequest(OHOS_SERVICE_MSG_UART_SEND,
                                             OHOS_SERVICE_CMD_START);
    }

    for (int i = 0; i < 200; ++i) {
        if (g_uart_service_msg_count >= baseMsgCnt + 3 &&
            g_uart_loopback_ok) {
            break;
        }
        LOS_TaskDelay(1);
    }

    uint32_t msgOk = (g_uart_service_msg_count >= baseMsgCnt + 3);
    uint32_t sendOk = (statusRet == EC_SUCCESS &&
                       selfTestRet == EC_SUCCESS &&
                       sendRet == EC_SUCCESS);
    uint32_t ok = (ready && sendOk && msgOk && g_uart_driver_init_ok && g_uart_loopback_ok);

    esp_rom_printf("[OHOS-S46A] UartLinkService selftest ready=%u send=%u msg=%u driverInit=%u loopOk=%u base=%u now=%u ok=%u\n",
                   ready,
                   sendOk,
                   msgOk,
                   g_uart_driver_init_ok,
                   g_uart_loopback_ok,
                   baseMsgCnt,
                   g_uart_service_msg_count,
                   ok);

    return ok ? LOS_OK : 1U;
}




static uint32_t UartLinkSendProtocolFrame(uint16_t cmdType,
                                          const uint8_t *payload,
                                          uint16_t payloadLen,
                                          const char *tag)
{
    uint8_t *frame = g_uart_tx_frame;
    uint16_t frameLen = 0;
    int encodeRet;
    int writeRet;
    uint32_t ok;

    if (payloadLen > OHOS_UART_PROTO_MAX_PAYLOAD_LEN) {
        esp_rom_printf("[OHOS-S47H] tx frame tag=%s cmd=0x%04x payload too large len=%u\n",
                       tag ? tag : "null",
                       cmdType,
                       payloadLen);
        return 0;
    }

    encodeRet = OhosUartProtoEncode(cmdType,
                                    payload,
                                    payloadLen,
                                    frame,
                                    OHOS_UART_PROTO_MAX_FRAME_LEN,
                                    &frameLen,
                                    0);

    if (encodeRet != OHOS_UART_PROTO_OK) {
        esp_rom_printf("[OHOS-S47H] tx frame tag=%s cmd=0x%04x encodeRet=%d ok=0\n",
                       tag ? tag : "null",
                       cmdType,
                       encodeRet);
        return 0;
    }

    writeRet = uart_write_bytes(OHOS_UART_LINK_PORT, frame, frameLen);
    ok = (writeRet == (int)frameLen);
    g_uart_diag_tx_count++;

    esp_rom_printf("[WS63-UART-TX] cnt=%u tag=%s cmd=0x%04x name=%s payloadLen=%u frameLen=%u writeRet=%d ok=%u\n",
                   g_uart_diag_tx_count,
                   tag ? tag : "null",
                   cmdType,
                   OhosUartProtoCmdName(cmdType),
                   payloadLen,
                   frameLen,
                   writeRet,
                   ok);
    UartLinkDumpHex("[WS63-UART-TX-RAW]", frame, frameLen);

    esp_rom_printf("[OHOS-S47H] tx frame tag=%s cmd=0x%04x name=%s payloadLen=%u frameLen=%u writeRet=%d ok=%u\n",
                   tag ? tag : "null",
                   cmdType,
                   OhosUartProtoCmdName(cmdType),
                   payloadLen,
                   frameLen,
                   writeRet,
                   ok);

    return ok;
}

